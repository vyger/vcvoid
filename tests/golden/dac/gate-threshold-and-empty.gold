# Bits are gate inputs: a value below the 0.1 (1 V) gate-high threshold reads as
# 0. Block A: bit1 driven at 0.05 (low) with bit2 high -> value 2, not 6.
# Block B: no bits patched at all -> the all-zeros sequence -> output = minimum.
patch <<<
[dac]
    bit1   = I1
    bit2   = I2
    bit3   = I3
    output = O1
>>>

patch <<<
[dac]
    minimum = 0.3
    output  = O2
>>>

# bit1=0.05 (below threshold -> low), bit2=1 -> value 2 -> 2/7
@0 set I1 0.05
@0 set I2 1
@0 expect O1 0.285714 tol 1e-5
@0 expect O2 0.3
# bit1 now 1 (high) -> value 6 -> 6/7
@1 set I1 1
@1 expect O1 0.857143 tol 1e-5
@1 expect O2 0.3
