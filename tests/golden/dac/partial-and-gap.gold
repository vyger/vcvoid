# Resolution N = highest patched bit index ("the LSB is the highest input you
# actually patch"), and patching may be non-contiguous (unpatched interior bits
# read as 0/low).
# Block A: N=2 (bit1,bit2) -> value/3.
# Block B: bit1 and bit3 patched, bit2 not -> N=3, bit2 reads 0 -> value/7.
patch <<<
[dac]
    bit1   = I1
    bit2   = I2
    output = O1
>>>

patch <<<
[dac]
    bit1   = I3
    bit3   = I4
    output = O2
>>>

# A: bit1=1 -> value 2 -> 2/3 ; B: bit1=1,bit3=1 -> value 5 (bit2=0) -> 5/7
@0 set I1 1
@0 set I3 1
@0 set I4 1
@0 expect O1 0.666667 tol 1e-5
@0 expect O2 0.714286 tol 1e-5

# A: bit2=1 only -> value 1 -> 1/3 ; B: bit1=1 only -> value 4 -> 4/7
@1 set I1 0
@1 set I2 1
@1 set I4 0
@1 expect O1 0.333333 tol 1e-5
@1 expect O2 0.571429 tol 1e-5
