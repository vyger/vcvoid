# Note selection: only select1 (root I), select3 (III) and select5 (V) on ->
# allowed = {0,4,7} (C major triad within C lydian). direction default up.
patch <<<
[minifonion]
    input   = I1
    output  = O2
    select1 = 1
    select3 = 1
    select5 = 1
>>>
# C (pc0) allowed
@0 set I1 0
@0 expect O2 0 tol 1e-5
# C# (1 semi): up past 2,3 -> E (4 semi)
@1 set I1 0.0083333
@1 expect O2 0.0333333 tol 1e-5
# F (5 semi): up past 6 -> G (7 semi)
@2 set I1 0.0416667
@2 expect O2 0.0583333 tol 1e-5
# G# (8 semi): up past 9,10,11 -> C one octave up (12 semi = 0.1)
@3 set I1 0.0666667
@3 expect O2 0.1 tol 1e-5
