# Compare and ifequal values can be live signals and negative. compare1=I2,
# ifequal1=I3, else=I4; match is exact equality including negatives.
patch <<<
[multicompare]
    input    = I1
    compare1 = I2
    ifequal1 = I3
    else     = I4
    output   = O1
>>>
# input == compare1 (both -0.3) -> ifequal1 value
@0 set I1 -0.3
@0 set I2 -0.3
@0 set I3 0.5
@0 set I4 0.8
@0 expect O1 0.5
# ifequal1 value changes live -> output follows (still matching)
@1 set I3 0.6
@1 expect O1 0.6
# compare1 changes so input no longer matches -> else value
@2 set I2 -0.2
@2 expect O1 0.8
