# multicompare worked example: match input against compare values (exact
# equality) and output the paired ifequal; else the fallback. Here (values kept
# in engine range): input==0.5 -> 0.1, ==0.7 -> 0.2, ==0.98 -> 0.3, else -> 0.9.
patch <<<
[multicompare]
    input    = I1
    compare1 = 0.5
    ifequal1 = 0.1
    compare2 = 0.7
    ifequal2 = 0.2
    compare3 = 0.98
    ifequal3 = 0.3
    else     = 0.9
    output   = O1
>>>
@0 set I1 0.5
@0 expect O1 0.1
@1 set I1 0.7
@1 expect O1 0.2
@2 set I1 0.98
@2 expect O1 0.3
# no match -> else
@3 set I1 0.6
@3 expect O1 0.9
@4 set I1 0
@4 expect O1 0.9
