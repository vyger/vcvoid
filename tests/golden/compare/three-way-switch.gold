# compare worked example (three-way switch with precision): input vs compare
# with a 0.1 equality band -> ifless / ifequal / ifgreater. compare=0.5.
# (Manual uses 0/1/2; 2 would clamp at the ±10 V output, so ifgreater=0.9 here.)
# Test values stay clear of the exact 0.1 boundary to avoid float ambiguity:
# diffs of 0.05/0.08 count as equal; 0.2 counts as less/greater.
patch <<<
[compare]
    input     = I1
    compare   = I2
    precision = 0.1
    ifless    = 0
    ifequal   = 0.5
    ifgreater = 0.9
    output    = O1
>>>
@0 set I2 0.5
@0 set I1 0.3
@0 expect O1 0
@1 set I1 0.45
@1 expect O1 0.5
@2 set I1 0.5
@2 expect O1 0.5
@3 set I1 0.55
@3 expect O1 0.5
@4 set I1 0.7
@4 expect O1 0.9
@5 set I1 0.42
@5 expect O1 0.5
@6 set I1 0.58
@6 expect O1 0.5
