# compare worked example 2: `else` sets the value when the condition is not met.
# ifless=1, else=-1: less -> 1, greater/equal -> -1.
patch <<<
[compare]
    input   = I1
    compare = 0.5
    ifless  = 1
    else    = -1
    output  = O1
>>>
@0 set I1 0.3
@0 expect O1 1
@1 set I1 0.7
@1 expect O1 -1
@2 set I1 0.5
@2 expect O1 -1
