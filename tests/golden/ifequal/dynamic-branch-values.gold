# The ifequal/else branch values can be live signals, read each tick.
# input2=0.5 (constant); ifequal=I3, else=I4.
patch <<<
[ifequal]
    input1  = I1
    input2  = 0.5
    ifequal = I3
    else    = I4
    output  = O1
>>>
# equal -> ifequal value (0.3)
@0 set I1 0.5
@0 set I3 0.3
@0 set I4 0.8
@0 expect O1 0.3
# ifequal value changes live -> output follows (still equal)
@1 set I3 0.6
@1 expect O1 0.6
# input1 changes -> not equal -> else value (0.8)
@2 set I1 0.4
@2 expect O1 0.8
