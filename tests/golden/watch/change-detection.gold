# watch mode 1: change detection with hysteresis. On the first tick the circuit
# samples the input; thereafter a `changed` trigger fires when the input differs
# from the last-sampled value by MORE than `histeresis` (strict >), and the new
# value becomes the sample. changedup / changeddown give the direction. Triggers
# are 10 ms = 1 tick at tickrate 100.
#
# histeresis 0.05.
#   t0: sample = 0.0, no trigger.
#   t1: input 0.10, |0.10-0.0| = 0.10 > 0.05  -> changed + changedup; sample=0.10
#   t5: input 0.12, |0.12-0.10| = 0.02 <= 0.05 -> no trigger (sample stays 0.10)
#   t8: input 0.03, |0.03-0.10| = 0.07 > 0.05  -> changed + changeddown; sample=0.03
tickrate 100
patch <<<
[watch]
    input       = I1
    histeresis  = 0.05
    changed     = O1
    changedup   = O2
    changeddown = O3
>>>
@0 set I1 0
@0 expect O1 0 tol 1e-4
@1 set I1 0.10
@1 expect O1 1 tol 1e-4
@1 expect O2 1 tol 1e-4
@1 expect O3 0 tol 1e-4
@2 expect O1 0 tol 1e-4
@5 set I1 0.12
@5 expect O1 0 tol 1e-4
@8 set I1 0.03
@8 expect O1 1 tol 1e-4
@8 expect O2 0 tol 1e-4
@8 expect O3 1 tol 1e-4
@9 expect O1 0 tol 1e-4
