# triggerdelay: `mute` suppresses any output gate that WOULD START while mute is
# high, but a gate already in progress finishes normally. delay = 0.1 s
# (10 ticks), repeats = 3, gatelength = 0.03 s (3 ticks). A 1-tick input trigger
# at t0 schedules three output gates starting at t10, t20, t30 (each 3 ticks).
#
# mute (I3) is raised at t11 (while gate 1, started t10, is still high) and held
# through t25:
#   gate 1 (start t10, mute LOW at its start) -> fires, and finishes normally
#           t10..12 even though mute rises mid-gate at t11.
#   gate 2 (start t20, mute HIGH) -> suppressed entirely.
#   gate 3 (start t30, mute LOW again since t26) -> fires t30..32.
tickrate 100
patch <<<
[triggerdelay]
    input      = I1
    output     = O1
    mute       = I3
    delay      = 0.1
    repeats    = 3
    gatelength = 0.03
>>>
@0 set I1 1
@1 set I1 0
@11 set I3 1
@26 set I3 0
@10 expect O1 1 tol 1e-4
@12 expect O1 1 tol 1e-4
@13 expect O1 0 tol 1e-4
@20 expect O1 0 tol 1e-4
@21 expect O1 0 tol 1e-4
@22 expect O1 0 tol 1e-4
@30 expect O1 1 tol 1e-4
@32 expect O1 1 tol 1e-4
@33 expect O1 0 tol 1e-4
