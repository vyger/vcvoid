# `outputsignal`: instead of passing the clock through, the given value is sent
# to the output "the whole time while the current step is active" -- i.e. held
# across the clock's low phase until the next clock, not gated by the clock.
# With outputsignal=1 and length=4 beats=2 ({0,2}): output is 1 for the whole
# beat step (incl. clock-low), offbeats is 1 for the whole non-beat step.
# Contrast with pattern-and-passthrough where output drops to 0 when clock is low.
patch <<<
[euklid]
    clock        = I1
    length       = 4
    beats        = 2
    outputsignal = 1
    output       = O1
    offbeats     = O2
>>>
@0 expect O1 0
@0 expect O2 0
# step0 (beat): output held high across clock high AND low
@1 set I1 1
@1 expect O1 1
@1 expect O2 0
@2 set I1 0
@2 expect O1 1
@2 expect O2 0
# step1 (off): offbeats held high across clock high AND low
@3 set I1 1
@3 expect O1 0
@3 expect O2 1
@4 set I1 0
@4 expect O1 0
@4 expect O2 1
# step2 (beat) again
@5 set I1 1
@5 expect O1 1
@6 set I1 0
@6 expect O1 1
