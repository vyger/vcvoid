# vcotuner: select gating. Manual: led* outputs only work while the circuit is
# selected; `intune` works regardless ("also while the circuit is not
# selected"). I1 is a Master18 gate input driving select.
master 18
patch <<<
# LABELS: master=18
[vcotuner]
    smooth = 0
    select = I1
    ledintune = O1
    ledflat = O2
    intune = O3
>>>
@0 set I1 0
@0 probe 440
@0 expect O1 0
@0 expect O3 1
@1 set I1 1
@1 expect O1 1
@1 expect O3 1
