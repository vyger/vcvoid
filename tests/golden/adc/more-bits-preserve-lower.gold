# "Adding more bits never changes the behaviour of bit1" (and, more generally,
# adding bits below only refines resolution -- the higher bits keep their value).
# Two adc instances read the SAME input register I1 over the default range:
#   block A: 3 bits -> O1,O2,O3
#   block B: 4 bits -> O4,O5,O6,O7
# For any input, A's b1..b3 must equal B's b1..b3; B just adds one finer bit.
#
#   input       A: floor(in*8)  bits(b1b2b3)   B: floor(in*16)  bits(b1b2b3b4)
#   0.59375     4  = 100                        9  = 1001
#   0.28125     2  = 010                        4  = 0100
# (0.59375=19/32 and 0.28125=9/32 are exact; *8 and *16 give x.5 midpoints.)
patch <<<
[adc]
    input = I1
    bit1 = O1
    bit2 = O2
    bit3 = O3
>>>

patch <<<
[adc]
    input = I1
    bit1 = O4
    bit2 = O5
    bit3 = O6
    bit4 = O7
>>>

@0 set I1 0.59375
@0 expect O1 1
@0 expect O2 0
@0 expect O3 0
@0 expect O4 1
@0 expect O5 0
@0 expect O6 0
@0 expect O7 1

@1 set I1 0.28125
@1 expect O1 0
@1 expect O2 1
@1 expect O3 0
@1 expect O4 0
@1 expect O5 1
@1 expect O6 0
@1 expect O7 0
