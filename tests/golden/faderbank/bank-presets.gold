# faderbank: immediate preset switching (preset input, no load/save triggers).
# Switching the preset saves the whole bank's current values into the old slot,
# loads the new slot, and the motors move all faders to the recalled values.
#   @1 move faders to 0.3 / 0.6 (these become preset 0's values)
#   @2 switch to preset 1 -> bank recalls seeded 0, faders drop
#   @3 move fader 1 to 0.8 in preset 1
#   @4 switch back to preset 0 -> 0.3 / 0.6 recalled, faders move back
tickrate 100
patch <<<
[m4]

[faderbank]
    firstfader = 1
    preset     = I1
    output1    = O1
    output2    = O2
>>>
@0 expect O1 0 tol 1e-4
@1 move F1 0.3
@1 move F2 0.6
@1 expect O1 0.3 tol 1e-4
@1 expect O2 0.6 tol 1e-4
@2 set I1 1
@2 expect O1 0 tol 1e-4
@2 expect O2 0 tol 1e-4
@2 expect F1 0 tol 1e-4
@3 move F1 0.8
@3 expect O1 0.8 tol 1e-4
@4 set I1 0
@4 expect O1 0.3 tol 1e-4
@4 expect O2 0.6 tol 1e-4
@4 expect F1 0.3 tol 1e-4
@4 expect F2 0.6 tol 1e-4
