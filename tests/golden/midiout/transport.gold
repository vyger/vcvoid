# midiout transport (manual lines 242-247, 372-374). A trigger into start emits a
# START (0xFA); into stop emits a STOP (0xFC). The running gate combines both: a
# rising edge sends START, a falling edge sends STOP. midiout has no `continue`
# jack, so no 0xFB is produced. START/STOP are realtime, not channel-bound.
tickrate 1000
x7 1
patch <<<
[midiout]
    start   = I1
    stop    = I2
    running = I3
    activesensing = 0
>>>
@0 expectmidi trs none
@1 set I1 1
@1 expectmidi trs start
@2 set I1 0
@2 expectmidi trs none
@3 set I2 1
@3 expectmidi trs stop
@4 set I2 0
@4 expectmidi trs none
@10 set I3 1
@10 expectmidi trs start
@11 expectmidi trs none
@20 set I3 0
@20 expectmidi trs stop
@21 expectmidi trs none
