# pot: triggered presets store the virtual pot value. Patching preset/loadpreset/
# savepreset puts the pot in virtual mode (isSelected true throughout since no
# select). preset=I6 (=0), savepreset=I7, loadpreset=I8.
#   t0 phys .5 -> v .5              -> O1 .5
#   t1 phys ->1: pickup .5->1.0     -> O1 1
#   t3 savepreset -> slot0 = 1.0
#   t5 phys ->.5: pickup 1->0.5 (v -= .5*1/1) -> O1 .5
#   t7 loadpreset -> v = 1.0         -> O1 1
tickrate 100
patch <<<
[p2b8]

[pot]
    pot        = P1.1
    output     = O1
    preset     = I6
    savepreset = I7
    loadpreset = I8
>>>
@0 set P1.1 0.5
@0 expect O1 0.5 tol 1e-4
@1 set P1.1 1.0
@1 expect O1 1 tol 1e-4
@3 set I7 1
@4 set I7 0
@5 set P1.1 0.5
@5 expect O1 0.5 tol 1e-4
@7 set I8 1
@7 expect O1 1 tol 1e-4
@8 set I8 0
