# pot: center notch. notch=0.2 -> flat zone [0.4, 0.6] all maps to 0.5; the
# outer regions rescale so endpoints still reach 0 and 1. outputscale=1.
#   x in [0.4,0.6] -> 0.5  (bipolar 0 -> exact center is easy to hit)
#   x=0.2 -> 0.2/0.4*0.5 = 0.25
#   x=0.8 -> 0.5 + (0.8-0.6)/0.4*0.5 = 0.75
#   x=0.0 -> 0 ; x=1.0 -> 1
tickrate 100
patch <<<
[p2b8]

[pot]
    pot     = P1.1
    notch   = 0.2
    output  = O1
    bipolar = O2
>>>
@0 set P1.1 0.5
@0 expect O1 0.5 tol 1e-4
@0 expect O2 0 tol 1e-4
@1 set P1.1 0.45
@1 expect O1 0.5 tol 1e-4
@1 expect O2 0 tol 1e-4
@2 set P1.1 0.4
@2 expect O1 0.5 tol 1e-4
@3 set P1.1 0.2
@3 expect O1 0.25 tol 1e-4
@3 expect O2 -0.5 tol 1e-4
@4 set P1.1 0.8
@4 expect O1 0.75 tol 1e-4
@4 expect O2 0.5 tol 1e-4
@5 set P1.1 0.0
@5 expect O1 0 tol 1e-4
@6 set P1.1 1.0
@6 expect O1 1 tol 1e-4
