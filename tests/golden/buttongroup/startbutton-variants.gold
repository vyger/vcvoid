# buttongroup: the three startbutton seedings, one circuit each (distinct output
# registers, no leds so there is no duplicate-output problem). Same values
# 0.1/0.2/0.4 on buttons 1..3.
#   startbutton 1  (min1/max1): active {1}       -> output 0.1
#   startbutton -1 (min1/max2): fill first 2 -> {1,2} -> output 0.3
#   startbutton 0  (min0/max3): active {}         -> output 0
tickrate 100
patch <<<
[buttongroup]
    button1 = B1.1
    button2 = B1.2
    button3 = B1.3
    value1  = 0.1
    value2  = 0.2
    value3  = 0.4
    startbutton = 1
    output  = O1
>>>

patch <<<
[buttongroup]
    button1 = B1.1
    button2 = B1.2
    button3 = B1.3
    value1  = 0.1
    value2  = 0.2
    value3  = 0.4
    startbutton = -1
    maxactive   = 2
    output  = O2
>>>

patch <<<
[p2b8]

[buttongroup]
    button1 = B1.1
    button2 = B1.2
    button3 = B1.3
    value1  = 0.1
    value2  = 0.2
    value3  = 0.4
    startbutton = 0
    minactive   = 0
    maxactive   = 3
    output  = O3
>>>
@0 expect O1 0.1 tol 1e-4
@0 expect O2 0.3 tol 1e-4
@0 expect O3 0 tol 1e-4
