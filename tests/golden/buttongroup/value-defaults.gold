# buttongroup: the two consumers of value<i> have DIFFERENT documented defaults
# when value<i> is unpatched -- the `output` sum uses i-1 (0,1,2,...), while
# buttonoutput<i> uses 1 ("If valueX is not defined ... the value 1 is output").
# No value inputs here. minactive 0 / maxactive 2, startbutton 0.
#   t1 press1 -> {1}: output = valueOut(1) = 0; buttonoutput1 = 1
#   t3 press2 -> {1,2}: output = 0 + valueOut(2)=1 -> 1; buttonoutput2 = 1
tickrate 100
patch <<<
[p2b8]

[buttongroup]
    button1 = B1.1
    button2 = B1.2
    buttonoutput1 = O2
    buttonoutput2 = O3
    minactive = 0
    maxactive = 2
    startbutton = 0
    output  = O1
>>>
@0 expect O1 0 tol 1e-4
@0 expect O2 0 tol 1e-4
@0 expect O3 0 tol 1e-4
@1 set B1.1 1
@1 expect O1 0 tol 1e-4
@1 expect O2 1 tol 1e-4
@2 set B1.1 0
@3 set B1.2 1
@3 expect O1 1 tol 1e-4
@3 expect O2 1 tol 1e-4
@3 expect O3 1 tol 1e-4
@4 set B1.2 0
