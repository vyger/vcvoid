# buttongroup: `clear` reseeds the start selection (startbutton), `clearall` also
# wipes all presets. Radio group, startbutton defaults to 1. clear=I1,
# savepreset=I7 (value-carrying -> slot 0), loadpreset=I8, clearall=I3.
#   t0: {1} (startbutton 1) -> output 0.1
#   t1 press2 -> {2}        -> output 0.2
#   t3 clear -> reseed {1}   -> output 0.1
#   t5 press3 -> {3}        -> output 0.3
#   t7 savepreset (0.2 -> slot 0) -> preset0 = {3}
#   t9 clearall -> reseed {1} AND every preset = {1}
#   t11 loadpreset (0.2 -> slot 0) -> {1} (preset0 was wiped) -> output 0.1
tickrate 100
patch <<<
[p2b8]

[buttongroup]
    button1 = B1.1
    button2 = B1.2
    button3 = B1.3
    value1  = 0.1
    value2  = 0.2
    value3  = 0.3
    output  = O1
    clear      = I1
    savepreset = I7
    loadpreset = I8
    clearall   = I3
>>>
@0 expect O1 0.1 tol 1e-4
@1 set B1.2 1
@1 expect O1 0.2 tol 1e-4
@2 set B1.2 0
@3 set I1 1
@3 expect O1 0.1 tol 1e-4
@4 set I1 0
@5 set B1.3 1
@5 expect O1 0.3 tol 1e-4
@6 set B1.3 0
@7 set I7 0.2
@8 set I7 0
@9 set I3 1
@9 expect O1 0.1 tol 1e-4
@10 set I3 0
@11 set I8 0.2
@11 expect O1 0.1 tol 1e-4
@12 set I8 0
