# buttongroup: classic radio buttons (minactive=maxactive=1 defaults). Exactly
# one button is active; selecting another evicts the previous; pressing the
# already-active button is refused (selection unchanged -> extrapress).
# startbutton defaults to 1 -> button1 active at boot. buttonpress = O8,
# selectionchanged = O6, extrapress = O7. values 0/0.1/0.2/0.3.
#   t0: active {1}       -> led1 1, output 0
#   t1: press 2 -> {2}   -> led1 0, led2 1, output 0.1, buttonpress+selchanged
#   t3: press 3 -> {3}   -> led3 1, output 0.2, buttonpress+selchanged
#   t5: press 3 (active) -> refused, still {3}, output 0.2, buttonpress+extrapress
tickrate 100
patch <<<
[p2b8]

[buttongroup]
    button1 = B1.1
    button2 = B1.2
    button3 = B1.3
    button4 = B1.4
    led1    = L1.1
    led2    = L1.2
    led3    = L1.3
    led4    = L1.4
    value1  = 0
    value2  = 0.1
    value3  = 0.2
    value4  = 0.3
    output  = O1
    buttonpress      = O8
    selectionchanged = O6
    extrapress       = O7
>>>
@0 expect L1.1 1 tol 1e-4
@0 expect L1.2 0 tol 1e-4
@0 expect O1 0 tol 1e-4
@1 set B1.2 1
@1 expect L1.1 0 tol 1e-4
@1 expect L1.2 1 tol 1e-4
@1 expect O1 0.1 tol 1e-4
@1 expect O8 1 tol 1e-4
@1 expect O6 1 tol 1e-4
@1 expect O7 0 tol 1e-4
@2 set B1.2 0
@2 expect O8 0 tol 1e-4
@2 expect O6 0 tol 1e-4
@3 set B1.3 1
@3 expect L1.3 1 tol 1e-4
@3 expect L1.2 0 tol 1e-4
@3 expect O1 0.2 tol 1e-4
@3 expect O6 1 tol 1e-4
@4 set B1.3 0
@5 set B1.3 1
@5 expect L1.3 1 tol 1e-4
@5 expect O1 0.2 tol 1e-4
@5 expect O8 1 tol 1e-4
@5 expect O7 1 tol 1e-4
@5 expect O6 0 tol 1e-4
@6 set B1.3 0
