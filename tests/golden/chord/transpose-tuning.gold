# chord transpose + tuningmode (shared output stage). C major 7 voiced C/E/G/B.
# transpose = 0.0166667 (2 semitones) is added to every output when not tuning.
#   O1..O4 = semis 0/4/7/11 + 2 = 2/6/9/13 -> 0.0166667/0.05/0.075/0.1083334
# tuningmode (I1) high -> every output emits tuningpitch (0.05), overriding.
patch <<<
[chord]
    output1     = O1
    output2     = O2
    output3     = O3
    output4     = O4
    transpose   = 0.0166667
    tuningmode  = I1
    tuningpitch = 0.05
>>>
# not tuning: chord + transpose
@0 expect O1 0.0166667 tol 1e-5
@0 expect O2 0.05 tol 1e-5
@0 expect O3 0.075 tol 1e-5
@0 expect O4 0.1083334 tol 1e-5
# tuningmode on: all four outputs = tuningpitch
@1 set I1 1
@1 expect O1 0.05 tol 1e-5
@1 expect O2 0.05 tol 1e-5
@1 expect O3 0.05 tol 1e-5
@1 expect O4 0.05 tol 1e-5
# tuningmode off: back to chord + transpose
@2 set I1 0
@2 expect O1 0.0166667 tol 1e-5
@2 expect O4 0.1083334 tol 1e-5
