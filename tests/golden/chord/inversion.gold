# chord `inversion`: forces which selected note is the lowest. C major 7
# (default, voices C/E/G/B). pitch=0, spread=0.
#  - inversion=2 -> the 2nd selected note (E) is the lowest -> O1..O4.
#      voicing anchored on E(4): C->12, E->4, G->7, B->11
#      O1=C(12), O2=E(4), O3=G(7), O4=B(11)
#  - inversion=3 -> the 3rd selected note (G) is the lowest -> O5..O8.
#      voicing anchored on G(7): C->12, E->16, G->7, B->11
#      O5=C(12), O6=E(16), O7=G(7), O8=B(11)
patch <<<
[chord]
    output1   = O1
    output2   = O2
    output3   = O3
    output4   = O4
    inversion = 2
>>>
patch <<<
[chord]
    output1   = O5
    output2   = O6
    output3   = O7
    output4   = O8
    inversion = 3
>>>
@0 expect O1 0.1 tol 1e-5
@0 expect O2 0.0333333 tol 1e-5
@0 expect O3 0.0583333 tol 1e-5
@0 expect O4 0.0916667 tol 1e-5
@0 expect O5 0.1 tol 1e-5
@0 expect O6 0.1333333 tol 1e-5
@0 expect O7 0.0583333 tol 1e-5
@0 expect O8 0.0916667 tol 1e-5
