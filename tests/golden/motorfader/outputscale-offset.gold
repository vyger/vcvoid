# motorfader: outputscale/outputoffset apply to the (0..1) fader value as
# output = value * outputscale + outputoffset (kept inside the O register's
# -1..1 clamp).
#   value 0.4 -> 0.4*0.5 + 0.2 = 0.4
#   value 1.0 -> 1.0*0.5 + 0.2 = 0.7
tickrate 100
patch <<<
[m4]

[motorfader]
    fader        = 1
    startvalue   = 0.4
    outputscale  = 0.5
    outputoffset = 0.2
    output       = O1
>>>
@0 expect O1 0.4 tol 1e-4
@0 expect F1 0.4 tol 1e-4
@1 move F1 1.0
@1 expect O1 0.7 tol 1e-4
@1 expect F1 1.0 tol 1e-4
