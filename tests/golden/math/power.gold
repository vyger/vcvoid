# math: power (input1^input2), covering every case the manual documents.
# Results (8, 16, -8, 1e9) exceed [-1,1], so N registers are used as probes.
#
# Note: the base=0 cases below OMIT the input1 line rather than binding it
# to some other unset I register, to avoid a same-tick I<->N read/write
# hazard (N registers feed an unpatched same-numbered I register's default;
# see product-quotient.gold's comment for the full explanation). Omitting
# the line reads the plain 0.0 framework default directly.
#
#   input1 > 0                       -> ordinary real power. 2^3 = 8.
#   input1 < 0                       -> input2 rounded to nearest integer,
#                                        then integer exponentiation (sign
#                                        follows exponent parity).
#     (-2)^round(3.6)=(-2)^4 = 16 (even -> positive)
#     (-2)^round(2.6)=(-2)^3 = -8 (odd -> negative)
#   input1 = 0, input2 > 0           -> 0.  0^5 = 0.
#   input1 = 0, input2 < 0           -> "a very large number is output".
#     0^(-3) -> +1e9 (kLarge). Sign not specified by the manual for this
#     case (0 has no sign in normal patch use) -- SPEC-GAP: convention is +.
#   input1 = 0, input2 = 0 (both omitted here, reading as the framework
#     default 0.0 for each) -> not addressed by the manual at all.
#     SPEC-GAP: implemented as 1.0 (matches std::pow(0,0) convention);
#     conventions unverified vs hardware.
patch <<<
[math]
    input1 = I1
    input2 = I2
    power  = N1

[math]
    input1 = I3
    input2 = I4
    power  = N2

[math]
    input1 = I3
    input2 = I5
    power  = N3

[math]
    input2 = I7
    power  = N4

[math]
    input2 = I8
    power  = N5

[math]
    power  = N6
>>>

@0 set I1 2.0
@0 set I2 3.0
@0 set I3 -2.0
@0 set I4 3.6
@0 set I5 2.6
@0 set I7 5.0
@0 set I8 -3.0
@0 expect N1 8.0 tol 1e-5
@0 expect N2 16.0 tol 1e-5
@0 expect N3 -8.0 tol 1e-5
@0 expect N4 0.0 tol 1e-6
@0 expect N5 1e9 tol 1.0
@0 expect N6 1.0 tol 1e-6
