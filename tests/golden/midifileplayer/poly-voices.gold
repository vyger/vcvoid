# midifileplayer: polyphonic playback (manual "Polyphonic tracks"). File B
# (div 96): noteon 60 @0, noteon 64 @48, noteoff 60 @96, noteoff 64 @144,
# EOT @144. Engine ticks (x31.25): 0 / 1500 / 3000 / 4500.
# Circuit 1: two voices — first-free allocation puts 60 on voice 1, 64 on
# voice 2. 60 -> 0.3, 64 -> (64-24)/120 = 0.33333.
# Circuit 2: ONE voice with voiceallocation = 1 (omit): the overlapping 64 is
# dropped, 60 holds its gate until 3000 and the voice stays silent after.
midifile 1 4D546864000000060000000100604D54726B0000001400903C643090406430803C003080400000FF2F00
patch <<<
[midifileplayer]
    loop = 0
    pitch1 = O1
    gate1 = O2
    pitch2 = O3
    gate2 = O4

[midifileplayer]
    loop = 0
    voiceallocation = 1
    pitch1 = O5
    gate1 = O6
>>>
@0 expect O2 1
@0 expect O1 0.3 tol 0.0005
@0 expect O4 0
@1490 expect O4 0
@1510 expect O4 1
@1510 expect O3 0.33333 tol 0.0005
@1510 expect O5 0.3 tol 0.0005
@1510 expect O6 1
@2990 expect O2 1
@3010 expect O2 0
@3010 expect O4 1
@3010 expect O6 0
@4490 expect O4 1
@4510 expect O4 0
