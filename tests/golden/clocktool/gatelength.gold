# gatelength sets a fixed output pulse length in seconds (independent of the
# clock). 0.05 s = 5 ticks at tickrate 100. divide=2 -> gates at t0, t20, t40,
# each 5 ticks long (high t0..t4, low from t5).
tickrate 100
patch <<<
[clocktool]
    clock      = I1
    divide     = 2
    gatelength = 0.05
    output     = O1
>>>
@0 set I1 1
@0 expect O1 1
@1 set I1 0
@4 expect O1 1
@5 expect O1 0
@10 set I1 1
@11 set I1 0
@20 set I1 1
@20 expect O1 1
@21 set I1 0
@24 expect O1 1
@25 expect O1 0
