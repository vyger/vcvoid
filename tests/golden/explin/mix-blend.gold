# `mix` blends dry (input) and wet (linear) output: output = input + mix*(wet-input).
# input=0.2 with startvalue=0.8, endvalue=0.05 -> wet=0.4.
#   mix=0   -> 0.2 (dry = input unchanged)
#   mix=0.5 -> 0.3 (halfway)
#   mix=1   -> 0.4 (full wet / linear)
#   mix=2   -> 0.6 (overcompensated beyond linear)
patch <<<
[explin]
    input      = I1
    startvalue = 0.8
    endvalue   = 0.05
    mix        = I2
    output     = O1
>>>
@0 set I1 0.2
@0 set I2 0
@0 expect O1 0.2 tol 1e-5
@1 set I2 0.5
@1 expect O1 0.3 tol 1e-5
@2 set I2 1
@2 expect O1 0.4 tol 1e-5
@3 set I2 2
@3 expect O1 0.6 tol 1e-5
