# nudge: `offset` is added to the output (octave-switch pattern) and with no
# minimum/maximum the value is unbounded (fine-tune pattern). amount=0.1,
# offset=I1. Also proves `wrap` is a no-op without bounds (per the Inputs table
# it requires both) -- three downs go straight past zero to -0.3.
#   t0 offset .35, value 0            -> O1 0.35
#   t1 up -> value .1                 -> O1 0.45
#   t3/t5/t7 down x3 -> value 0 -> -0.1 -> -0.2 (no bound stops it)
#   t9 offset -> 0                    -> O1 -0.2
tickrate 100
patch <<<
[p2b8]

[nudge]
    amount     = 0.1
    wrap       = 1
    buttonup   = B1.1
    buttondown = B1.3
    output     = O1
    offset     = I1
>>>
@0 set I1 0.35
@0 expect O1 0.35 tol 1e-4
@1 set B1.1 1
@1 expect O1 0.45 tol 1e-4
@2 set B1.1 0
@3 set B1.3 1
@3 expect O1 0.35 tol 1e-4
@4 set B1.3 0
@5 set B1.3 1
@5 expect O1 0.25 tol 1e-4
@6 set B1.3 0
@7 set B1.3 1
@7 expect O1 0.15 tol 1e-4
@8 set B1.3 0
@9 set I1 0
@9 expect O1 -0.2 tol 1e-4
