# nudge: the manual's CV-source example scaled to registers: min=-0.2 max=0.2
# amount=0.1 (i.e. -2V..2V in 1V steps). buttonup=B1.1, buttondown=B1.3,
# output=O1, changed=O2. startvalue default 0.
#   t1 up   -> 0.1     changed pulses (1 tick at tickrate 100)
#   t3 up   -> 0.2     (max reached)
#   t5 up   -> clamped, stays 0.2 -> NO changed pulse
#   t7 down -> 0.1     changed pulses
#   t9 BOTH pressed -> reset to startvalue 0, changed pulses
#   t12 BOTH again  -> already at start -> NO changed pulse
tickrate 100
patch <<<
[p2b8]

[nudge]
    minimum    = -0.2
    maximum    = 0.2
    amount     = 0.1
    buttonup   = B1.1
    buttondown = B1.3
    output     = O1
    changed    = O2
>>>
@0 expect O1 0 tol 1e-4
@0 expect O2 0 tol 1e-4
@1 set B1.1 1
@1 expect O1 0.1 tol 1e-4
@1 expect O2 1 tol 1e-4
@2 set B1.1 0
@2 expect O2 0 tol 1e-4
@3 set B1.1 1
@3 expect O1 0.2 tol 1e-4
@4 set B1.1 0
@5 set B1.1 1
@5 expect O1 0.2 tol 1e-4
@5 expect O2 0 tol 1e-4
@6 set B1.1 0
@7 set B1.3 1
@7 expect O1 0.1 tol 1e-4
@7 expect O2 1 tol 1e-4
@8 set B1.3 0
@9 set B1.1 1
@9 set B1.3 1
@9 expect O1 0 tol 1e-4
@9 expect O2 1 tol 1e-4
@10 set B1.1 0
@10 set B1.3 0
@12 set B1.1 1
@12 set B1.3 1
@12 expect O1 0 tol 1e-4
@12 expect O2 0 tol 1e-4
@13 set B1.1 0
@13 set B1.3 0
