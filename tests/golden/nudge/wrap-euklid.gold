# nudge: the manual's euklid-beats example -- one button, integer steps, wrap.
# amount=1, minimum=3, maximum=7, wrap=1, buttonup=B1.1. The default startvalue 0
# is clamped into the bound range -> starts at 3. Values 3..7 exceed the +-1
# clamp of O registers, so route through an internal cable consumed by a copy.
#   presses: 3 -> 4 -> 5 -> 6 -> 7 -> wrap -> 3
tickrate 100
patch <<<
[p2b8]

[nudge]
    amount   = 1
    buttonup = B1.1
    minimum  = 3
    maximum  = 7
    wrap     = 1
    output   = _BEATS

[copy]
    input  = _BEATS * 0.1
    output = O1
>>>
@0 expect _BEATS 3 tol 1e-4
@1 set B1.1 1
@1 expect _BEATS 4 tol 1e-4
@2 set B1.1 0
@3 set B1.1 1
@3 expect _BEATS 5 tol 1e-4
@4 set B1.1 0
@5 set B1.1 1
@5 expect _BEATS 6 tol 1e-4
@6 set B1.1 0
@7 set B1.1 1
@7 expect _BEATS 7 tol 1e-4
@8 set B1.1 0
@9 set B1.1 1
@9 expect _BEATS 3 tol 1e-4
@10 set B1.1 0
