# `gate`: when patched, slew limiting is active only while the gate is high;
# while low it is like slew=0 (the output follows the input immediately).
# slew=1, tickrate 100 (linear step 0.001/tick when active).
tickrate 100
patch <<<
[slew]
    input  = I1
    slew   = 1
    gate   = I2
    linear = O1
>>>
# gate low -> passthrough (instant), even on a big jump
@0 set I1 0.4
@0 expect O1 0.4
@1 set I1 0.9
@1 expect O1 0.9
# gate high -> slew limited from 0.9
@2 set I2 1
@2 expect O1 0.9
@3 set I1 0.94
@3 expect O1 0.901 tol 1e-6
@4 expect O1 0.902 tol 1e-6
