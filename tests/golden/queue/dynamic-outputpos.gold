# outputpos may be CV controlled and changes take effect immediately (no clock
# needed) since the output just reads the addressed cell each tick. Push
# 0.1,0.2,0.3 -> cells 0.3,0.2,0.1, then sweep outputpos1 across positions 1..3.
patch <<<
[queue]
    input      = I1
    clock      = I2
    outputpos1 = I3
    output1    = O1
>>>
@1 set I1 0.1
@1 set I2 1
@2 set I2 0
@3 set I1 0.2
@3 set I2 1
@4 set I2 0
@5 set I1 0.3
@5 set I2 1
@6 set I2 0
# cells now 0.3,0.2,0.1; move the read position without clocking
@7 set I3 1
@7 expect O1 0.3
@8 set I3 2
@8 expect O1 0.2
@9 set I3 3
@9 expect O1 0.1
