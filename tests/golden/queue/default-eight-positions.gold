# If outputpos1..8 are not wired, the eight outputs default to positions 1..8.
# Pushing 0.1,0.2,...,0.8 fills cells 1..8 with 0.8,0.7,...,0.1, so output_k
# (=cell k) reads 0.8,0.7,...,0.1 respectively.
patch <<<
[queue]
    input   = I1
    clock   = I2
    output1 = O1
    output2 = O2
    output3 = O3
    output4 = O4
    output5 = O5
    output6 = O6
    output7 = O7
    output8 = O8
>>>
@1 set I1 0.1
@1 set I2 1
@2 set I2 0
@3 set I1 0.2
@3 set I2 1
@4 set I2 0
@5 set I1 0.3
@5 set I2 1
@6 set I2 0
@7 set I1 0.4
@7 set I2 1
@8 set I2 0
@9 set I1 0.5
@9 set I2 1
@10 set I2 0
@11 set I1 0.6
@11 set I2 1
@12 set I2 0
@13 set I1 0.7
@13 set I2 1
@14 set I2 0
@15 set I1 0.8
@15 set I2 1
@15 expect O1 0.8
@15 expect O2 0.7
@15 expect O3 0.6
@15 expect O4 0.5
@15 expect O5 0.4
@15 expect O6 0.3
@15 expect O7 0.2
@15 expect O8 0.1
