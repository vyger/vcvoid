# Outputs can be placed at any cell via outputpos. Here output1/2/3 read cells
# 1, 3, 5. After pushing 0.1..0.5, cells (1-based) are 0.5,0.4,0.3,0.2,0.1, so
# pos1=0.5, pos3=0.3, pos5=0.1.
patch <<<
[queue]
    input      = I1
    clock      = I2
    outputpos1 = 1
    outputpos2 = 3
    outputpos3 = 5
    output1    = O1
    output2    = O2
    output3    = O3
>>>
@1 set I1 0.1
@1 set I2 1
@2 set I2 0
@3 set I1 0.2
@3 set I2 1
@4 set I2 0
@5 set I1 0.3
@5 set I2 1
# after 3 pushes: cells 0.3,0.2,0.1 -> pos1=0.3, pos3=0.1, pos5=empty(0)
@5 expect O1 0.3
@5 expect O2 0.1
@5 expect O3 0
@6 set I2 0
@7 set I1 0.4
@7 set I2 1
@8 set I2 0
@9 set I1 0.5
@9 set I2 1
# after 5 pushes: cells 0.5,0.4,0.3,0.2,0.1 -> pos1=0.5, pos3=0.3, pos5=0.1
@9 expect O1 0.5
@9 expect O2 0.3
@9 expect O3 0.1
