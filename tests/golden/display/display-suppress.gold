# display: display=0 suppresses all writes; an out-of-range display=N is inert.
# SPEC-GAP (display.md is silent on both): `display = 0` means "no screen" so the
# circuit never writes anywhere; `display = 9` with no such DB8E is treated as
# inert hardware (mirrors G8's absent-hardware tolerance), NOT a load error.
# The single real DB8E (D1) therefore stays OFF even though both circuits have a
# changing value.
tickrate 100
patch <<<
[db8e]

[display]
    display = 0
    value   = I1

[display]
    display = 9
    value   = I2
>>>
@0 set I1 0.5
@0 set I2 0.7
@0 expectdisplay D1 off
@1 set I1 0.9
@1 expectdisplay D1 off
