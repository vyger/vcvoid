# Unpatched minimum/maximum apply no bound on that side. foldby defaults to 0.1.
#  A: only minimum=0.2 -> folds up below it, passes through above.
#  B: only maximum=0.3 -> folds down above it, passes through below.
#  C: neither bound patched (foldby default 0.1) -> pure passthrough ("useless").
patch <<<
[fold]
    input   = I1
    foldby  = 0.1
    minimum = 0.2
    output  = O1
>>>

patch <<<
[fold]
    input   = I2
    foldby  = 0.1
    maximum = 0.3
    output  = O2
>>>

patch <<<
[fold]
    input   = I3
    output  = O3
>>>

# A: 0.05 < 0.2 -> +0.1 twice -> 0.25 ; 0.5 has no upper bound -> unchanged
@0 set I1 0.05
@0 set I2 0.55
@0 set I3 0.5
@0 expect O1 0.25 tol 1e-6
# B: 0.55 > 0.3 -> -0.1 thrice -> 0.25
@0 expect O2 0.25 tol 1e-6
# C: no bounds -> passthrough
@0 expect O3 0.5 tol 1e-6

@1 set I1 0.5
@1 set I2 -0.5
@1 set I3 -0.3
@1 expect O1 0.5 tol 1e-6
@1 expect O2 -0.5 tol 1e-6
@1 expect O3 -0.3 tol 1e-6
