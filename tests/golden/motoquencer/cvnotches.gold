# motoquencer: cvnotches puts the CV fader into notched-integer mode (cvbase/range/
# quantize ignored). cvnotches=2 -> a binary switch outputting 0 or 1. The fader
# snaps to the nearest of the two dents.
tickrate 100
patch <<<
[m4]
[motoquencer]
    clock     = I1
    cvnotches = 2
    cv        = O1
>>>
@1 move F1 0.7
@1 expect F1 1.0 tol 1e-4
@2 set I1 1
@2 expect O1 1 tol 1e-4
@3 set I1 0
@3 move F1 0.3
@3 expect F1 0.0 tol 1e-4
@4 set I1 1
@5 set I1 0
@6 set I1 1
@6 expect O1 0 tol 1e-4
