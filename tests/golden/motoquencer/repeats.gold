# motoquencer: `repeats` makes a step last several clock cycles. Here step 1 is set
# to 3 repeats (edited in fadermode 3), so a 2-step sequence lasts 1 + 3 = 4 clocks.
# The default gate pattern ("once") gates only the FIRST repetition, so step 1's
# gate fires on its first clock and is silent on the two repeats.
#
# repeats fadermode-3 notch: 16 dents, notch k rests at k/15; k=2 -> repeats=3.
# The period must be known before the tested step, so step 1 (the 2nd step, reached
# on the 2nd clock edge) is used rather than step 0 (whose period is not yet learned).
tickrate 100
patch <<<
[m4]
[motoquencer]
    clock     = I1
    fadermode = I2
    numsteps  = 2
    cv        = O1
    gate      = O2
>>>
# tick1: show repeats mode (recall). tick2: set step 1 repeats = 3.
@1 set I2 3
@2 move F2 0.1333333
@2 expect F2 0.1333333 tol 1e-4
# tick3: back to pitch mode.
@3 set I2 0
# clock: step0 (1 clock) then step1 (3 clocks, gate only on the first).
@4 set I1 1
@5 set I1 0
@6 set I1 1
@6 expect O2 1 tol 1e-4
@7 set I1 0
@7 expect O2 0 tol 1e-4
@8 set I1 1
@8 expect O2 0 tol 1e-4
@9 set I1 0
@10 set I1 1
@10 expect O2 0 tol 1e-4
@11 set I1 0
# 5th edge: step1's 3 repeats are done -> wrap to step 0, which gates again.
@12 set I1 1
@12 expect O2 1 tol 1e-4
