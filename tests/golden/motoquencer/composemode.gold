# motoquencer: composemode (finding). While `composemode` is high the sequencer
# stops clocking — clock edges are ignored and no step is played. Instead, editing
# a step's CV (fadermode 0) jumps to that step, outputs the changed CV and opens
# the gate for a short 10 ms window ("so you can listen to the changed note").
# quantize=0 + cvbase=0/cvrange=1 makes the fader map linearly to the CV so the
# edited value is predictable. At tickrate 100 the 10 ms audition gate is 1 tick.
tickrate 100
patch <<<
[m4]
[motoquencer]
    clock       = I1
    composemode = 1
    quantize    = 0
    cvbase      = 0
    cvrange     = 1
    defaultcv   = 0
    numsteps    = 4
    cv          = O1
    gate        = O2
>>>
# clock edges are ignored while composing: no gate, no step advance.
@1 set I1 1
@1 expect O2 0 tol 1e-4
@2 set I1 0
@3 set I1 1
@3 expect O1 0 tol 1e-4
@3 expect O2 0 tol 1e-4
@4 set I1 0
# edit step 0's CV -> jump to it, output the CV, open a 10 ms gate.
@5 move F1 0.5
@5 expect O1 0.5 tol 1e-3
@5 expect O2 1 tol 1e-4
# gate closes after ~10 ms (1 tick @ tr100); CV holds the edited value.
@6 expect O1 0.5 tol 1e-3
@6 expect O2 0 tol 1e-4
# clock is still ignored: another edge produces no gate, CV unchanged.
@7 set I1 1
@7 expect O1 0.5 tol 1e-3
@7 expect O2 0 tol 1e-4
@8 set I1 0
# edit a different step -> jump there and audition it.
@9 move F2 0.25
@9 expect O1 0.25 tol 1e-3
@9 expect O2 1 tol 1e-4
@10 expect O2 0 tol 1e-4
