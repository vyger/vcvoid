# motoquencer "I Feel Lucky": luckygates sets each affected step's gate on with
# probability luckyamount. The two extremes are deterministic: amount 1 => all gates
# on, amount 0 => all gates off. Here we start from all-off (defaultgate=0), turn
# every gate ON with luckyamount=1, observe the gate firing, then turn every gate
# OFF with luckyamount=0 and observe silence. Gate is read on the played step (a
# fadermode-0 display never touches the gate lane, so no recall is needed).
tickrate 100
patch <<<
[m4]
[motoquencer]
    numfaders   = 4
    quantize    = 0
    defaultgate = 0
    clock       = I1
    gate        = O2
    luckygates  = I2
    luckyamount = I3
>>>
@0 expect O2 0 tol 1e-4
# amount = 1, fire luckygates -> every gate on.
@1 set I3 1
@2 set I2 1
@3 set I2 0
# first clock edge: step 0 plays (period unknown -> gate follows clock level).
@4 set I1 1
@4 expect O2 1 tol 1e-4
@5 set I1 0
@5 expect O2 0 tol 1e-4
# second edge (period=2): step 1 plays, one-tick gate window at its start.
@6 set I1 1
@6 expect O2 1 tol 1e-4
@7 set I1 0
# now clear every gate: amount = 0, fire luckygates again.
@8 set I3 0
@9 set I2 1
@10 set I2 0
# subsequent steps are silent.
@11 set I1 1
@11 expect O2 0 tol 1e-4
@12 set I1 0
@13 set I1 1
@13 expect O2 0 tol 1e-4
