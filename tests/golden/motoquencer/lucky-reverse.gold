# motoquencer "I Feel Lucky": luckyreverse reverses the playing order of the
# affected steps together with all their attributes (here just the CV). luckyamount
# has no influence; the op is deterministic. Scope 0 + luckychance 1 => all four
# steps participate, so 0.1/0.3/0.6/0.9 becomes 0.9/0.6/0.3/0.1.
tickrate 100
patch <<<
[m4]
[motoquencer]
    numfaders    = 4
    quantize     = 0
    cvbase       = 0
    cvrange      = 1
    holdcv       = 0
    clock        = I1
    cv           = O1
    luckyreverse = I2
>>>
@0 expect O1 0 tol 1e-4
@1 move F1 0.1
@1 move F2 0.3
@1 move F3 0.6
@1 move F4 0.9
# tick2: fire luckyreverse -> cvpos becomes 0.9/0.6/0.3/0.1.
@2 set I2 1
@3 set I2 0
@4 set I1 1
@4 expect O1 0.9 tol 1e-4
@5 set I1 0
@6 set I1 1
@6 expect O1 0.6 tol 1e-4
@7 set I1 0
@8 set I1 1
@8 expect O1 0.3 tol 1e-4
@9 set I1 0
@10 set I1 1
@10 expect O1 0.1 tol 1e-4
