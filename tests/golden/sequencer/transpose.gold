# pitchoutput = stagePitch * outputscaling + transpose. transpose is a live CV
# added after scaling, so changing it moves the output immediately (no clock
# needed).
patch <<<
[sequencer]
    clock         = I1
    transpose     = I2
    outputscaling = I3
    pitchoutput   = O1
    pitch1        = 0.10
>>>
# 0.10 * 2 + 0.05 = 0.25
@0 set I3 2
@0 set I2 0.05
@0 set I1 1
@0 expect O1 0.25 tol 1e-5
@1 set I1 0
# transpose changes live: 0.10 * 2 + 0.10 = 0.30
@2 set I2 0.10
@2 expect O1 0.30 tol 1e-5
