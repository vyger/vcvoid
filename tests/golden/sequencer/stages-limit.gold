# `stages` limits how many step inputs are used. Four pitches are defined but
# stages=2 restricts the sequence to the first two, so it alternates 0.10/0.20.
patch <<<
[sequencer]
    clock       = I1
    stages      = 2
    pitchoutput = O1
    pitch1      = 0.10
    pitch2      = 0.20
    pitch3      = 0.30
    pitch4      = 0.40
>>>
@0 set I1 1
@0 expect O1 0.10 tol 1e-5
@1 set I1 0
@2 set I1 1
@2 expect O1 0.20 tol 1e-5
@3 set I1 0
@4 set I1 1
@4 expect O1 0.10 tol 1e-5
@5 set I1 0
@6 set I1 1
@6 expect O1 0.20 tol 1e-5
