# Manual example 1: a 4-voltage CV sequencer. Each clock trigger advances one
# step; the pitch output cycles through pitch1..pitch4. Unpatched gatelength
# feeds the clock through 1:1, so gateoutput mirrors the clock while the step's
# gate is on (unpatched gates default on).
patch <<<
[sequencer]
    clock       = I1
    pitchoutput = O1
    gateoutput  = O2
    pitch1      = 0.10
    pitch2      = 0.20
    pitch3      = 0.30
    pitch4      = 0.40
>>>
@0 set I1 1
@0 expect O1 0.10 tol 1e-5
@0 expect O2 1
@1 set I1 0
@1 expect O1 0.10 tol 1e-5
@1 expect O2 0
@2 set I1 1
@2 expect O1 0.20 tol 1e-5
@2 expect O2 1
@3 set I1 0
@4 set I1 1
@4 expect O1 0.30 tol 1e-5
@5 set I1 0
@6 set I1 1
@6 expect O1 0.40 tol 1e-5
@7 set I1 0
@8 set I1 1
@8 expect O1 0.10 tol 1e-5
