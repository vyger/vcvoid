# encoder: outputscale/outputoffset. Range 0.2..0.5 via scale 0.3 then +0.2
# (manual "Choosing a different range of values"). output = value*0.3 + 0.2.
#   @0 pos 0 -> value 0 -> 0*0.3+0.2 = 0.2
#   @1 +96 -> value 1 -> 1*0.3+0.2 = 0.5
#   @2 -48 -> value 0.5 -> 0.5*0.3+0.2 = 0.35
tickrate 100
patch <<<
[e4]

[encoder]
    encoder      = E1.1
    output       = O1
    outputscale  = 0.3
    outputoffset = 0.2
    smooth       = 0
>>>
@0 expect O1 0.2 tol 1e-4
@1 turn E1.1 96
@1 expect O1 0.5 tol 1e-4
@2 turn E1.1 -48
@2 expect O1 0.35 tol 1e-4
