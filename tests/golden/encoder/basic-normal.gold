# encoder: basic normal mode. One 360 turn = 96 detents = a full 0.0..1.0 sweep
# at sensivity 1. smooth = 0 for exact steps. startvalue 0 -> dot at bottom-left
# (value 0). detent step = 1/96, so +48 -> +0.5.
#   @0 seed: pos 0 -> output 0
#   @1 +48 -> pos 0.5 -> output 0.5
#   @2 +48 -> pos 1.0 -> output 1.0
#   @3 +48 -> clamp pos 1.0 -> output 1.0
#   @4 -96 -> pos 0.0 -> output 0.0
tickrate 100
patch <<<
[e4]

[encoder]
    encoder = E1.1
    output  = O1
    smooth  = 0
>>>
@0 expect O1 0 tol 1e-4
@1 turn E1.1 48
@1 expect O1 0.5 tol 1e-4
@2 turn E1.1 48
@2 expect O1 1.0 tol 1e-4
@3 turn E1.1 48
@3 expect O1 1.0 tol 1e-4
@4 turn E1.1 -96
@4 expect O1 0.0 tol 1e-4
