# encoder: infinity and circular modes.
# encA mode 3 (positive infinity 0..inf): value = pos, clamped at 0 on the low
#   side, open above (the O jack itself clamps at +10V = 1.0, as on hardware).
#   detent step = sensivity/96.
#   @1 +48 -> 0.5 ; @2 -96 -> clamp at 0 ; @3 +96 -> 1.0
# encB mode 6 (circular 0..1, wraps both ways):
#   @1 +48 -> 0.5 ; @2 +48 -> wrap(1.0)=0.0 ; @3 -48 -> wrap(-0.5)=0.5
tickrate 100
patch <<<
[e4]

[encoder]
    encoder = E1.1
    output  = O1
    mode    = 3
    smooth  = 0

[encoder]
    encoder = E1.2
    output  = O2
    mode    = 6
    smooth  = 0
>>>
@0 expect O1 0 tol 1e-4
@0 expect O2 0 tol 1e-4
@1 turn E1.1 48
@1 turn E1.2 48
@1 expect O1 0.5 tol 1e-4
@1 expect O2 0.5 tol 1e-4
@2 turn E1.1 -96
@2 turn E1.2 48
@2 expect O1 0.0 tol 1e-4
@2 expect O2 0.0 tol 1e-4
@3 turn E1.1 96
@3 turn E1.2 -48
@3 expect O1 1.0 tol 1e-4
@3 expect O2 0.5 tol 1e-4
