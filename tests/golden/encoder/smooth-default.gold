# encoder: default smoothing (smooth = 0.5). The output is a one-pole low-pass of
# the stepped value so it does not jump. SPEC-GAP curve (encodercore.hpp):
# tau = smooth*kSmoothMax = 0.5*0.05 = 0.025 s -> a = 1-exp(-0.01/0.025)
# = 1-exp(-0.4) = 0.329680 per tick. A +96 detent jump targets value 1.0.
#   @1 +96 -> smoothed = 0 + (1.0-0)*0.329680 = 0.329680  (lags the step)
#   @50    -> converged to the target 1.0
tickrate 100
patch <<<
[e4]

[encoder]
    encoder = E1.1
    output  = O1
>>>
@1 turn E1.1 96
@1 expect O1 0.329680 tol 1e-4
@50 expect O1 1.0 tol 0.01
