# encoder: bipolar mode (mode = 2), range -1.0..+1.0, center at pos 0.5.
# outputscale = 2V = 0.2 -> output -2V..+2V. value = 2*pos - 1.
#   @0 pos 0 -> value -1 -> -1*0.2 = -0.2 (-2V)  [dot bottom-left]
#   @1 +48 -> pos 0.5 -> value 0 -> 0.0          [center, top]
#   @2 +48 -> pos 1.0 -> value 1 -> 0.2 (+2V)
tickrate 100
patch <<<
[e4]

[encoder]
    encoder     = E1.1
    output      = O1
    mode        = 2
    outputscale = 2V
    smooth      = 0
>>>
@0 expect O1 -0.2 tol 1e-4
@1 turn E1.1 48
@1 expect O1 0.0 tol 1e-4
@2 turn E1.1 48
@2 expect O1 0.2 tol 1e-4
