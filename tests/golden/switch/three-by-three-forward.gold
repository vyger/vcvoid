# Manual example 3 (switch.md:67): 3x3 switch. A forward trigger moves each
# output forward to the next input (equivalently each input backward to the
# previous output). offset 1: O_j = input[(j+1) mod 3]; offset 2: (j+2) mod 3.
patch <<<
[switch]
    input1 = I1
    input2 = I2
    input3 = I3
    output1 = O1
    output2 = O2
    output3 = O3
    forward = I8
>>>
@0 set I1 0.1
@0 set I2 0.2
@0 set I3 0.3
@0 expect O1 0.1
@0 expect O2 0.2
@0 expect O3 0.3
@1 set I8 1
@1 expect O1 0.2
@1 expect O2 0.3
@1 expect O3 0.1
@2 set I8 0
@3 set I8 1
@3 expect O1 0.3
@3 expect O2 0.1
@3 expect O3 0.2
