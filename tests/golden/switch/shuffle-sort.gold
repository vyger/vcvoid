# `shuffle` (switch.md:134): randomly assigns each output to a DISTINCT input
# (a permutation -- no input reused). `sort` (switch.md:135) undoes the shuffle
# back to ordered but CONSERVES the current offset (unlike reset, which zeroes
# it). The exact shuffled permutation is RNG-determined (seed 1); the SPEC
# invariant is that O1..O4 carry a permutation of {0.1,0.2,0.3,0.4} -- all four
# present, none repeated (verified by hand: see values below). offset/forward
# still work after shuffling. The sort branch (identity perm + conserved
# offset=1) is computed exactly from the manual, independent of the RNG.
seed 1
patch <<<
[switch]
    input1  = I1
    input2  = I2
    input3  = I3
    input4  = I4
    output1 = O1
    output2 = O2
    output3 = O3
    output4 = O4
    shuffle = I5
    sort    = I6
    forward = I8
>>>
@0 set I1 0.1
@0 set I2 0.2
@0 set I3 0.3
@0 set I4 0.4
@0 expect O1 0.1
@0 expect O2 0.2
@0 expect O3 0.3
@0 expect O4 0.4
# shuffle (seed 1) -> perm = [2,1,3,0]: O1<-input3, O2<-input2, O3<-input4,
# O4<-input1. A permutation of {0.1,0.2,0.3,0.4} -- all four present, none
# repeated (the distinctness invariant the manual guarantees).
@1 set I5 1
@1 expect O1 0.3
@1 expect O2 0.2
@1 expect O3 0.4
@1 expect O4 0.1
@2 set I5 0
# forward after shuffle advances each output one input: src = (perm[j]+1) mod 4
# -> O1<-input4, O2<-input3, O3<-input1, O4<-input2.
@3 set I8 1
@3 expect O1 0.4
@3 expect O2 0.3
@3 expect O3 0.1
@3 expect O4 0.2
@4 set I8 0
# sort restores identity but keeps offset=1: O_j = input[(j+1) mod 4]
@5 set I6 1
@5 expect O1 0.2
@5 expect O2 0.3
@5 expect O3 0.4
@5 expect O4 0.1
@6 set I6 0
