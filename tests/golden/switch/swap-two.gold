# Manual example (switch.md:98): 2 inputs + 2 outputs = a swap. offset 0:
# input1->output1, input2->output2. offset 1: input1->output2, input2->output1.
patch <<<
[switch]
    input1  = I1
    input2  = I2
    output1 = O1
    output2 = O2
    offset  = I7
>>>
@0 set I1 0.3
@0 set I2 0.7
@0 set I7 0
@0 expect O1 0.3
@0 expect O2 0.7
@1 set I7 1
@1 expect O1 0.7
@1 expect O2 0.3
