# `backward` (switch.md:132): like forward but decrements the internal offset
# (exercises the negative-modulo path). 4 inputs -> 1 output. From I1->O1, one
# backward step wraps to input4; a second to input3.
patch <<<
[switch]
    input1 = I1
    input2 = I2
    input3 = I3
    input4 = I4
    output1 = O1
    backward = I8
>>>
@0 set I1 0.1
@0 set I2 0.2
@0 set I3 0.3
@0 set I4 0.4
@0 expect O1 0.1
@1 set I8 1
@1 expect O1 0.4
@2 set I8 0
@3 set I8 1
@3 expect O1 0.3
