# delay: manual worked example 3 -- gate/trigger delay. Eight gate tracks run in
# parallel through the same tape; each gateoutN reproduces gateinN shifted by the
# delay. tickrate 100, delay 0.5 s = 50 ticks. Gates record 0/1 (high iff >= 0.1).
# Two independent tracks prove the eight gates are delayed independently.
#
# gatein1 (I1): high t0..2, low t3+       -> gateout1 (O1) high t50..52
# gatein2 (I2): high t10..14, low t15+    -> gateout2 (O2) high t60..64
tickrate 100
patch <<<
[delay]
    gatein1  = I1
    gatein2  = I2
    gateout1 = O1
    gateout2 = O2
    delay    = 0.5
>>>
@0 set I1 1
@3 set I1 0
@10 set I2 1
@15 set I2 0
@49 expect O1 0 tol 1e-4
@50 expect O1 1 tol 1e-4
@52 expect O1 1 tol 1e-4
@53 expect O1 0 tol 1e-4
@59 expect O2 0 tol 1e-4
@60 expect O2 1 tol 1e-4
@64 expect O2 1 tol 1e-4
@65 expect O2 0 tol 1e-4
