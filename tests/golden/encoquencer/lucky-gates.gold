# encoquencer "I Feel Lucky": the lucky surface lives in the shared SeqCore, so it
# works identically under the E4 encoder skin. luckygates with luckyamount=1 turns
# every affected step's gate on. Starting from all-off (defaultgate=0), a single
# trigger makes the sequence play. Observed through the gate output (encoders have
# no motor readback).
tickrate 100
patch <<<
[e4]
[encoquencer]
    numfaders   = 4
    quantize    = 0
    defaultgate = 0
    clock       = I1
    gate        = O2
    luckygates  = I2
>>>
@0 expect O2 0 tol 1e-4
# luckyamount defaults to 1: fire luckygates -> all gates on.
@1 set I2 1
@2 set I2 0
@3 set I1 1
@3 expect O2 1 tol 1e-4
@4 set I1 0
@4 expect O2 0 tol 1e-4
@5 set I1 1
@5 expect O2 1 tol 1e-4
