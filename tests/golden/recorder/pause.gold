# pause is a gate (state), not a trigger. While pausing during RECORD the tape
# stops moving and the input is not recorded (but still passed through). While
# pausing during PLAYBACK the tape holds and the output sticks at the current CV.
patch <<<
[recorder]
    cvin  = I1
    mode  = I2
    pause = I3
    cvout = O1
>>>
# record with a pause gap: 0.99 (during pause) is NOT recorded
@0 set I2 2
@0 set I1 0.10
@1 set I1 0.11
@2 set I3 1
@2 set I1 0.99
@2 expect O1 0.99 tol 1e-5
@3 set I3 0
@3 set I1 0.12
@4 set I1 0.13
# tape now holds [0.10, 0.11, 0.12, 0.13]
@5 set I2 1
@5 set I1 0.0
@5 expect O1 0.10 tol 1e-5
@6 expect O1 0.11 tol 1e-5
# pause during playback: output sticks at the current sample (0.12)
@7 set I3 1
@7 expect O1 0.12 tol 1e-5
@8 expect O1 0.12 tol 1e-5
@9 set I3 0
@9 expect O1 0.12 tol 1e-5
@10 expect O1 0.13 tol 1e-5
@11 expect O1 0.13 tol 1e-5
