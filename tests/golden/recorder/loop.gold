# loop = 1: when the playback finishes it restarts immediately from the start,
# cycling the recording indefinitely.
patch <<<
[recorder]
    cvin  = I1
    mode  = I2
    loop  = I4
    cvout = O1
>>>
# record 3 samples 0.10,0.11,0.12
@0 set I2 2
@0 set I1 0.10
@1 set I1 0.11
@2 set I1 0.12
# play looping
@3 set I2 1
@3 set I4 1
@3 expect O1 0.10 tol 1e-5
@4 expect O1 0.11 tol 1e-5
@5 expect O1 0.12 tol 1e-5
@6 expect O1 0.10 tol 1e-5
@7 expect O1 0.11 tol 1e-5
@8 expect O1 0.12 tol 1e-5
@9 expect O1 0.10 tol 1e-5
