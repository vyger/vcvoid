# Block A: a single patched input -> output/maximum/minimum/average all equal it.
# Block B: no inputs patched -> all outputs 0 (empty min/max/average).
patch <<<
[mixer]
    input1  = I1
    output  = O1
    maximum = O2
    minimum = O3
    average = O4
>>>

patch <<<
[mixer]
    output  = O5
    maximum = O6
    minimum = O7
    average = O8
>>>

@0 set I1 0.4
@0 expect O1 0.4
@0 expect O2 0.4
@0 expect O3 0.4
@0 expect O4 0.4
@0 expect O5 0
@0 expect O6 0
@0 expect O7 0
@0 expect O8 0
