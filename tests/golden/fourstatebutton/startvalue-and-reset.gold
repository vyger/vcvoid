# fourstatebutton: startvalue = 2 boots in state 2 (index 2, third state); a
# `reset` trigger returns to state 0. reset = I1.
#   t0 startvalue 2 -> state 2 -> output value3 0.3, led 2/3
#   t1 press -> state 3 -> output value4 0.4, led 1
#   t3 reset -> state 0 -> output value1 0.1, led 0
tickrate 100
patch <<<
[p2b8]

[fourstatebutton]
    button     = B1.1
    led        = L1.1
    value1     = 0.1
    value2     = 0.2
    value3     = 0.3
    value4     = 0.4
    startvalue = 2
    reset      = I1
    output     = O1
>>>
@0 expect O1 0.3 tol 1e-4
@0 expect L1.1 0.66667 tol 1e-3
@1 set B1.1 1
@1 expect O1 0.4 tol 1e-4
@1 expect L1.1 1 tol 1e-4
@2 set B1.1 0
@3 set I1 1
@3 expect O1 0.1 tol 1e-4
@3 expect L1.1 0 tol 1e-4
@4 set I1 0
