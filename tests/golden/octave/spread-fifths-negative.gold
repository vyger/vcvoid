# Negative spread extrapolates the fifths ladder DOWNWARD (SPEC-GAP note 4):
# the octave/fifth offset table is odd-symmetric about 0, so negative levels
# mirror the positive ones (level -1 -> -7 st, -2 -> -12 st, -3 -> -19 st,
# -8 -> -48 st) instead of C++ truncating division folding them upward.
# 1 semitone = 0.1/12 engine units; a perfect fifth = 7 semitones = 0.0583333.
patch <<<
[octave]
    input   = I1
    spread  = I2
    fifths  = I3
    output2 = O2
    output3 = O3
>>>
@0 set I1 0
@0 set I3 1
# spread -0.125 -> round(-1.0)=-1 -> a perfect fifth down (-7 st) on output3
@0 set I2 -0.125
@0 expect O3 -0.0583333 tol 1e-5
@0 expect O2 -0.0291667 tol 1e-5
# spread -0.25 -> round(-2.0)=-2 -> one octave down (-12 st)
@1 set I2 -0.25
@1 expect O3 -0.1 tol 1e-5
@1 expect O2 -0.05 tol 1e-5
# spread -0.375 -> round(-3.0)=-3 -> octave + fifth down (-19 st = -0.1583333)
@2 set I2 -0.375
@2 expect O3 -0.1583333 tol 1e-5
@2 expect O2 -0.0791667 tol 1e-5
# spread -1.0 -> round(-8.0)=-8 -> four octaves down (mirror of the endpoint)
@3 set I2 -1
@3 expect O3 -0.4 tol 1e-5
@3 expect O2 -0.2 tol 1e-5
