# fifths = on inserts a perfect-fifth (7 semitone) step between each octave, so
# output3 steps through 0, 5th, 8ve, 8ve+5th, 2*8ve, ... (manual pg 355:
# "intermediate steps shift the pitch by perfect fifths"). Endpoint spread=1.0
# still reaches four octaves on output3 / two octaves on output2.
# 1 semitone = 0.1/12 engine units; a perfect fifth = 7 semitones = 0.0583333.
#
# SPEC-GAP: literal reading -> output3 offset = table[round(spread*8)] with
# table = {0,7,12,19,24,31,36,43,48} semitones; output2 = half of output3.
patch <<<
[octave]
    input   = I1
    spread  = I2
    fifths  = I3
    output2 = O2
    output3 = O3
>>>
@0 set I1 0
@0 set I3 1
# spread 0.125 -> round(1.0)=1 -> a perfect fifth up (7 st) on output3
@0 set I2 0.125
@0 expect O3 0.0583333 tol 1e-5
@0 expect O2 0.0291667 tol 1e-5
# spread 0.25 -> round(2.0)=2 -> one octave (12 st)
@1 set I2 0.25
@1 expect O3 0.1 tol 1e-5
@1 expect O2 0.05 tol 1e-5
# spread 0.375 -> round(3.0)=3 -> octave + fifth (19 st = 0.1583333)
@2 set I2 0.375
@2 expect O3 0.1583333 tol 1e-5
@2 expect O2 0.0791667 tol 1e-5
# spread 1.0 -> round(8.0)=8 -> four octaves (documented endpoint)
@3 set I2 1
@3 expect O3 0.4 tol 1e-5
@3 expect O2 0.2 tol 1e-5
