# branches: bar b uses branch 1 (even b) or 2+min(ctz((b+1)/2), branches-1)
# (odd b) -- the ruler sequence A B A C for branches=2. The branch number salts
# the hash so each branch freezes its own decisions; `branch` outputs the
# number. activity=0.75 -> round(0.75*16)=12 random beats/bar (no buttons).
tickrate 100
patch <<<
[algoquencer]
    clock    = I1
    activity = 0.75
    branches = 2
    trigger  = O1
    branch   = _BR
>>>
patch <<<
[copy]
    input  = _BR
    output = O2
>>>
@1 set I1 1
@1 expect _BR 1 tol 1e-5   # bar0: branch 1
@2 set I1 0
@3 set I1 1
@4 set I1 0
@5 set I1 1
@6 set I1 0
@7 set I1 1
@8 set I1 0
@9 set I1 1
@9 expect O1 0 tol 1e-5   # bar0 (branch A) step 4
@10 set I1 0
@11 set I1 1
@12 set I1 0
@13 set I1 1
@14 set I1 0
@15 set I1 1
@16 set I1 0
@17 set I1 1
@18 set I1 0
@19 set I1 1
@20 set I1 0
@21 set I1 1
@22 set I1 0
@23 set I1 1
@24 set I1 0
@25 set I1 1
@26 set I1 0
@27 set I1 1
@28 set I1 0
@29 set I1 1
@30 set I1 0
@31 set I1 1
@32 set I1 0
@33 set I1 1
@33 expect _BR 2 tol 1e-5   # bar1: branch 2
