# algoquencer as Turing machine (manual: 'Pseudo random voltages'): clock only,
# defaults (length 16, dejavu 1, activity smart 0.5 -> round(0.5*16)=8 beats/bar,
# pitch in [0, 0.3]). The pattern repeats identically every 16 steps.
# SPEC-GAP: the PRNG is invented (splitmix-style hval/hUniform in
# engine/circuits/algoquencer.cpp); values computed by the algoref.py replica.
# Beat placement for the no-buttons case: round(activity*len) steps chosen by
# weighted keys u(j,K_ACT)^(1/w), flat weights at offbeats=distribution=0.5.
tickrate 100
patch <<<
[algoquencer]
    clock   = I1
    pitch   = O1
    trigger = O2
>>>
@0 expect O1 0 tol 1e-5   # before the first clock: nothing played yet
@1 set I1 1
@1 expect O1 0 tol 1e-5   # step 0: no beat, holds
@1 expect O2 0 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.105669 tol 1e-5   # step 1: beat
@3 expect O2 1 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0.145666 tol 1e-5   # step 2: beat
@5 expect O2 1 tol 1e-5
@6 set I1 0
@7 set I1 1
@7 expect O1 0.041336 tol 1e-5   # step 3: beat
@7 expect O2 1 tol 1e-5
@8 set I1 0
@9 set I1 1
@9 expect O1 0.041336 tol 1e-5   # step 4: no beat, holds
@9 expect O2 0 tol 1e-5
