# algoquencer mute/unmute, select gating, and triggered presets.
#  * mutebutton toggles beat suppression; muteled shows it. unmutebutton arms an
#    unmute that lands at the NEXT bar start; unmuteled blinks while armed
#    (SPEC-GAP: 2 Hz square, high when (tick/round(0.25*tickrate)) % 2 == 0).
#  * select gates step buttons and LEDs only; the sequencer keeps running and
#    the mutebutton stays live even while deselected (manual exception).
#  * presets (triggered mode: preset + savepreset + loadpreset all patched):
#    save/load snapshot the steps (and length/mute/seed state); clearall wipes
#    the current state AND all presets.
tickrate 100
patch <<<
[p2b8]

[algoquencer]
    clock        = I1
    select       = I3
    preset       = I5
    savepreset   = I6
    loadpreset   = I7
    clearall     = I8
    button1      = B1.1
    button2      = B1.2
    button3      = B1.3
    button4      = B1.4
    led1         = L1.1
    led2         = L1.2
    led3         = L1.3
    led4         = L1.4
    mutebutton   = B1.6
    unmutebutton = B1.7
    muteled      = L1.6
    unmuteled    = L1.7
    trigger      = O1
>>>
@0 set I3 1
# set step 0; clock plays it (length 4 from the four wired buttons)
@1 set B1.1 1
@2 set B1.1 0
@2 expect L1.1 1 tol 1e-5
@3 set I1 1
@3 expect O1 1 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0 tol 1e-5
@6 set I1 0
@6 set B1.6 1
@7 set B1.6 0
@7 set I1 1
@7 expect L1.6 1 tol 1e-5
@8 set I1 0
@9 set I1 1
@10 set I1 0
# muted: bar start (step 0) produces no trigger
@11 set I1 1
@11 expect O1 0 tol 1e-5
@11 expect L1.6 1 tol 1e-5
@12 set I1 0
# arm unmute; unmuteled blinks while waiting (high phase ticks 0-24, low 25-49)
@12 set B1.7 1
@13 set B1.7 0
@13 expect L1.7 1 tol 1e-5
@24 expect L1.7 1 tol 1e-5
@26 expect L1.7 0 tol 1e-5
# resume clock; unmute lands exactly at the next bar start: after the t11 bar
# start the position is step 0, so steps 1,2,3 play at t53/55/57 and the bar
# starts at t59.
@53 set I1 1
@53 expect O1 0 tol 1e-5
@54 set I1 0
@55 set I1 1
@56 set I1 0
@57 set I1 1
@58 set I1 0
@59 set I1 1
@59 expect O1 1 tol 1e-5
@59 expect L1.6 0 tol 1e-5
@59 expect L1.7 0 tol 1e-5
@60 set I1 0
# deselect: step-button presses are ignored, LEDs untouched, no phantom toggle
@62 set I3 0
@63 set B1.2 1
@64 set B1.2 0
@64 expect L1.2 0 tol 1e-5
@66 set I3 1
@67 expect L1.2 0 tol 1e-5
# mutebutton stays live while deselected
@68 set I3 0
@68 set B1.6 1
@69 set B1.6 0
@69 expect L1.6 1 tol 1e-5
@70 set B1.6 1
@71 set B1.6 0
@71 set I3 1
@71 expect L1.6 0 tol 1e-5
# triggered presets: save {0} to preset 0, edit to {0,1}, save to preset 1,
# then load each back. Setting `preset` alone must NOT load anything.
@72 set I5 0
@73 set I6 1
@74 set I6 0
@75 set B1.2 1
@76 set B1.2 0
@76 expect L1.2 1 tol 1e-5
@77 set I5 1
@78 set I6 1
@79 set I6 0
@80 set I5 0
@80 expect L1.2 1 tol 1e-5
@81 set I7 1
@82 set I7 0
@82 expect L1.2 0 tol 1e-5
@82 expect L1.1 1 tol 1e-5
@83 set I5 1
@84 set I7 1
@85 set I7 0
@85 expect L1.2 1 tol 1e-5
# clearall: wipes current state and all presets
@86 set I8 1
@87 set I8 0
@87 expect L1.1 0.5 tol 1e-5   # bit cleared; cursor (step 0 last played) remains
@87 expect L1.2 0 tol 1e-5
@88 set I7 1
@89 set I7 0
@89 expect L1.2 0 tol 1e-5
@89 expect L1.1 0.5 tol 1e-5   # still just the cursor
