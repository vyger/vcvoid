# activity/variation on a button pattern (manual: activity 0.5 = exact pattern,
# 0 = silence, 1 = every step; variation moves beats but preserves their count).
# 8 buttons -> smart length 8. Steps 0 and 4 are set (B1.1/B1.5 pressed at t0).
# Instance A sweeps activity via I4; instance B sweeps variation via I5.
tickrate 100
patch <<<
[p2b8]

[algoquencer]
    clock    = I1
    activity = I4
    button1  = B1.1
    button2  = B1.2
    button3  = B1.3
    button4  = B1.4
    button5  = B1.5
    button6  = B1.6
    button7  = B1.7
    button8  = B1.8
    trigger  = O1
>>>
patch <<<
[algoquencer]
    clock     = I1
    variation = I5
    button1   = B1.1
    button2   = B1.2
    button3   = B1.3
    button4   = B1.4
    button5   = B1.5
    button6   = B1.6
    button7   = B1.7
    button8   = B1.8
    trigger   = O2
>>>
@0 set I4 0.5
@0 set I5 0
@0 set B1.1 1
@0 set B1.5 1
@1 set B1.1 0
@1 set B1.5 0
@1 set I1 1
@1 expect O1 1 tol 1e-5   # bar0 a=0.5 exact pattern step 0
@1 expect O2 1 tol 1e-5   # bar0 v=0 exact pattern step 0
@2 set I1 0
@3 set I1 1
@3 expect O1 0 tol 1e-5   # bar0 a=0.5 exact pattern step 1
@3 expect O2 0 tol 1e-5   # bar0 v=0 exact pattern step 1
@4 set I1 0
@5 set I1 1
@5 expect O1 0 tol 1e-5   # bar0 a=0.5 exact pattern step 2
@5 expect O2 0 tol 1e-5   # bar0 v=0 exact pattern step 2
@6 set I1 0
@7 set I1 1
@7 expect O1 0 tol 1e-5   # bar0 a=0.5 exact pattern step 3
@7 expect O2 0 tol 1e-5   # bar0 v=0 exact pattern step 3
@8 set I1 0
@9 set I1 1
@9 expect O1 1 tol 1e-5   # bar0 a=0.5 exact pattern step 4
@9 expect O2 1 tol 1e-5   # bar0 v=0 exact pattern step 4
@10 set I1 0
@11 set I1 1
@11 expect O1 0 tol 1e-5   # bar0 a=0.5 exact pattern step 5
@11 expect O2 0 tol 1e-5   # bar0 v=0 exact pattern step 5
@12 set I1 0
@13 set I1 1
@13 expect O1 0 tol 1e-5   # bar0 a=0.5 exact pattern step 6
@13 expect O2 0 tol 1e-5   # bar0 v=0 exact pattern step 6
@14 set I1 0
@15 set I1 1
@15 expect O1 0 tol 1e-5   # bar0 a=0.5 exact pattern step 7
@15 expect O2 0 tol 1e-5   # bar0 v=0 exact pattern step 7
@16 set I1 0
@16 set I4 0
@17 set I1 1
@17 expect O1 0 tol 1e-5   # bar1 a=0: silence even on pattern beats
@18 set I1 0
@19 set I1 1
@20 set I1 0
@21 set I1 1
@22 set I1 0
@23 set I1 1
@24 set I1 0
@25 set I1 1
@25 expect O1 0 tol 1e-5   # bar1 a=0: silence even on pattern beats
@26 set I1 0
@27 set I1 1
@28 set I1 0
@29 set I1 1
@30 set I1 0
@31 set I1 1
@32 set I1 0
@32 set I4 1
@33 set I1 1
@33 expect O1 1 tol 1e-5   # bar2 a=1: beat on every step
@34 set I1 0
@35 set I1 1
@35 expect O1 1 tol 1e-5   # bar2 a=1: beat on every step
@36 set I1 0
@37 set I1 1
@37 expect O1 1 tol 1e-5   # bar2 a=1: beat on every step
