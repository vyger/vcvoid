@48 set I1 0
@48 set I4 0.5
@48 set I4 0.25
@49 set I1 1
@49 expect O1 1 tol 1e-5   # bar3 a=0.25 keeps 1 beat: step 0 -> 1
@50 set I1 0
@51 set I1 1
@52 set I1 0
@53 set I1 1
@54 set I1 0
@55 set I1 1
@56 set I1 0
@57 set I1 1
@57 expect O1 0 tol 1e-5   # bar3 a=0.25 keeps 1 beat: step 4 -> 0
@58 set I1 0
