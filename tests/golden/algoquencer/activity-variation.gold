@60 set I1 0
@61 set I1 1
@62 set I1 0
@63 set I1 1
@64 set I1 0
@64 set I5 0.5
@65 set I1 1
@65 expect O2 0 tol 1e-5   # bar4 v=0.5 step 0 -> 0 (count still 2)
@66 set I1 0
