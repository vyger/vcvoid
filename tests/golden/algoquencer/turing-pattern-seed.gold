# `pattern` seeds the pseudo-random stream: two instances with pattern 5 and 6
# produce different but individually stable sequences (dejavu 1). activity=1
# makes every step a beat so pitch changes each step.
tickrate 100
patch <<<
[algoquencer]
    clock    = I1
    pattern  = 5
    activity = 1
    pitch    = O1
>>>
patch <<<
[algoquencer]
    clock    = I1
    pattern  = 6
    activity = 1
    pitch    = O2
>>>
@1 set I1 1
@1 expect O1 0.00722 tol 1e-5   # pattern 5 step 0
@1 expect O2 0.276205 tol 1e-5   # pattern 6 step 0
@2 set I1 0
@3 set I1 1
@3 expect O1 0.133261 tol 1e-5   # pattern 5 step 1
@3 expect O2 0.126303 tol 1e-5   # pattern 6 step 1
@4 set I1 0
@5 set I1 1
@5 expect O1 0.260451 tol 1e-5   # pattern 5 step 2
@5 expect O2 0.271738 tol 1e-5   # pattern 6 step 2
@6 set I1 0
@7 set I1 1
@7 expect O1 0.005173 tol 1e-5   # pattern 5 step 3
@7 expect O2 0.274768 tol 1e-5   # pattern 6 step 3
@8 set I1 0
@9 set I1 1
@10 set I1 0
@11 set I1 1
@12 set I1 0
@13 set I1 1
@14 set I1 0
@15 set I1 1
@16 set I1 0
@17 set I1 1
@18 set I1 0
@19 set I1 1
@20 set I1 0
@21 set I1 1
@22 set I1 0
@23 set I1 1
@24 set I1 0
@25 set I1 1
@26 set I1 0
@27 set I1 1
@28 set I1 0
@29 set I1 1
@30 set I1 0
@31 set I1 1
@32 set I1 0
@33 set I1 1
@33 expect O1 0.00722 tol 1e-5   # pattern 5 repeats at step 16
@33 expect O2 0.276205 tol 1e-5   # pattern 6 repeats at step 16
@34 set I1 0
@35 set I1 1
@36 set I1 0
@37 set I1 1
@38 set I1 0
@39 set I1 1
@40 set I1 0
