# algoquencer `repeats` + melody mode. repeats=2 makes one bar = two passes of
# the 4-button pattern (8 steps): startofbar fires only every 8 steps. Wired
# pitch1..pitch4 turn the pitch output into a melody sequencer: step j plays
# pitch input ((j % length) % 16) + 1, so steps 4..7 reuse pitch1..pitch4.
# Beats on steps 0 and 2 (B1.1/B1.3), activity default 0.5 -> exact pattern.
tickrate 100
patch <<<
[p2b8]

[algoquencer]
    clock      = I1
    repeats    = 2
    button1    = B1.1
    button2    = B1.2
    button3    = B1.3
    button4    = B1.4
    pitch1     = 0.1
    pitch2     = 0.2
    pitch3     = 0.3
    pitch4     = 0.4
    pitch      = O1
    trigger    = O2
    startofbar = O3
>>>
@0 set B1.1 1
@0 set B1.3 1
@1 set B1.1 0
@1 set B1.3 0
@3 set I1 1
@3 expect O1 0.1 tol 1e-5
@3 expect O2 1 tol 1e-5
@3 expect O3 1 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O2 0 tol 1e-5
@5 expect O1 0.1 tol 1e-5
@6 set I1 0
@7 set I1 1
@7 expect O1 0.3 tol 1e-5
@7 expect O2 1 tol 1e-5
@8 set I1 0
@9 set I1 1
@10 set I1 0
# second pass of the pattern within the SAME bar: no startofbar, pitch1 again
@11 set I1 1
@11 expect O1 0.1 tol 1e-5
@11 expect O2 1 tol 1e-5
@11 expect O3 0 tol 1e-5
@12 set I1 0
@13 set I1 1
@14 set I1 0
@15 set I1 1
@15 expect O1 0.3 tol 1e-5
@16 set I1 0
@17 set I1 1
@18 set I1 0
# bar 2 starts after 8 steps
@19 set I1 1
@19 expect O3 1 tol 1e-5
@19 expect O1 0.1 tol 1e-5
@20 set I1 0
