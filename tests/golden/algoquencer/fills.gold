# fills add extra end-weighted beats: extra = max(1, round(fills*factor*len/4)),
# SPEC-GAP size factors -- fillorder 0: every bar x1.0; 2: bar2 x0.5 bar4 x1.0
# (1-based bars). 8 buttons, one beat (step 0). fills=1 -> 2 extra (fo=0);
# fo=2 -> 1 extra on bar1(0-based), 2 on bar3, none on bars 0/2. fillsled fires
# on fill beats.
tickrate 100
patch <<<
[p2b8]

[algoquencer]
    clock    = I1
    fills    = 1
    button1  = B1.1
    button2  = B1.2
    button3  = B1.3
    button4  = B1.4
    button5  = B1.5
    button6  = B1.6
    button7  = B1.7
    button8  = B1.8
    trigger  = O1
    fillsled = O2
>>>
patch <<<
[algoquencer]
    clock     = I1
    fills     = 1
    fillorder = 2
    button1   = B1.1
    button2   = B1.2
    button3   = B1.3
    button4   = B1.4
    button5   = B1.5
    button6   = B1.6
    button7   = B1.7
    button8   = B1.8
    trigger   = O3
    fillsled  = O4
>>>
@0 set B1.1 1
@1 set B1.1 0
@1 set I1 1
@1 expect O1 1 tol 1e-5   # fo=0 bar0 step 0
@1 expect O2 0 tol 1e-5   # fillsled step 0
@2 set I1 0
@3 set I1 1
@3 expect O1 1 tol 1e-5   # fo=0 bar0 step 1
@3 expect O2 1 tol 1e-5   # fillsled step 1
@4 set I1 0
@5 set I1 1
@5 expect O1 0 tol 1e-5   # fo=0 bar0 step 2
@5 expect O2 0 tol 1e-5   # fillsled step 2
@6 set I1 0
@7 set I1 1
@7 expect O1 0 tol 1e-5   # fo=0 bar0 step 3
@7 expect O2 0 tol 1e-5   # fillsled step 3
@7 expect O3 0 tol 1e-5   # fo=2 bar0: no fill bar
@8 set I1 0
@9 set I1 1
@9 expect O1 1 tol 1e-5   # fo=0 bar0 step 4
@9 expect O2 1 tol 1e-5   # fillsled step 4
@10 set I1 0
@11 set I1 1
@11 expect O1 0 tol 1e-5   # fo=0 bar0 step 5
@11 expect O2 0 tol 1e-5   # fillsled step 5
@12 set I1 0
@13 set I1 1
@13 expect O1 0 tol 1e-5   # fo=0 bar0 step 6
@13 expect O2 0 tol 1e-5   # fillsled step 6
@14 set I1 0
@15 set I1 1
@15 expect O1 0 tol 1e-5   # fo=0 bar0 step 7
@15 expect O2 0 tol 1e-5   # fillsled step 7
@16 set I1 0
@17 set I1 1
@18 set I1 0
@19 set I1 1
@19 expect O3 1 tol 1e-5   # fo=2 bar1 fill beat at step 1
@19 expect O4 1 tol 1e-5   # fo=2 bar1 fillsled
@20 set I1 0
@21 set I1 1
