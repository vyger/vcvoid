# pitchlow/pitchhigh set the random range; pitchresolution quantizes to N
# discrete levels: level = pitchlow + floor(u*N)/(N-1) * (ph-pl), N>=2
# (random.cpp's floor(u*steps) convention). res 2 -> {0.1, 0.5}; res 3 ->
# {0.1, 0.3, 0.5}. activity=1 so every step fires.
tickrate 100
patch <<<
[algoquencer]
    clock           = I1
    activity        = 1
    pitchlow        = 0.1
    pitchhigh       = 0.5
    pitchresolution = 2
    pitch           = O1
>>>
patch <<<
[algoquencer]
    clock           = I1
    activity        = 1
    pitchlow        = 0.1
    pitchhigh       = 0.5
    pitchresolution = 3
    pitch           = O2
>>>
@1 set I1 1
@1 expect O1 0.1 tol 1e-5   # res 2 step 0
@1 expect O2 0.3 tol 1e-5   # res 3 step 0
@2 set I1 0
@3 set I1 1
@3 expect O1 0.1 tol 1e-5   # res 2 step 1
@3 expect O2 0.3 tol 1e-5   # res 3 step 1
@4 set I1 0
@5 set I1 1
@5 expect O1 0.1 tol 1e-5   # res 2 step 2
@5 expect O2 0.3 tol 1e-5   # res 3 step 2
@6 set I1 0
@7 set I1 1
@7 expect O1 0.1 tol 1e-5   # res 2 step 3
@7 expect O2 0.1 tol 1e-5   # res 3 step 3
@8 set I1 0
@9 set I1 1
@9 expect O1 0.5 tol 1e-5   # res 2 step 4
@9 expect O2 0.5 tol 1e-5   # res 3 step 4
@10 set I1 0
@11 set I1 1
@11 expect O1 0.5 tol 1e-5   # res 2 step 5
@11 expect O2 0.5 tol 1e-5   # res 3 step 5
@12 set I1 0
@13 set I1 1
@14 set I1 0
@15 set I1 1
@16 set I1 0
@17 set I1 1
@18 set I1 0
@19 set I1 1
@20 set I1 0
