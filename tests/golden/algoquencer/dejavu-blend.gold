# dejavu blends deterministic vs chaotic per step: step j is deterministic iff
# hUniform(seed,0,j,K_CLASS,0) < dejavu (SPEC-GAP classification -- monotone in
# dejavu). Deterministic steps repeat their pitch every bar; chaotic steps are
# redrawn each bar from the engine RNG (6 draws per chaotic step per bar, at
# bar entry, ascending step, kinds PITCH,VARREM,VARADD,ACT,FILL,ROLL).
# activity=1 (all steps fire) isolates the pitch behavior.
tickrate 100
patch <<<
[algoquencer]
    clock    = I1
    activity = 1
    dejavu   = 0.6
    pitch    = O1
>>>
@1 set I1 1
@1 expect O1 0.000019 tol 1e-5   # bar0 chaotic step 0
@2 set I1 0
@3 set I1 1
@3 expect O1 0.105669 tol 1e-5   # bar0 det step 1
@4 set I1 0
@5 set I1 1
@6 set I1 0
@7 set I1 1
@8 set I1 0
@9 set I1 1
@10 set I1 0
@11 set I1 1
@12 set I1 0
@13 set I1 1
@14 set I1 0
@15 set I1 1
@16 set I1 0
@17 set I1 1
@18 set I1 0
@19 set I1 1
@20 set I1 0
@21 set I1 1
@22 set I1 0
@23 set I1 1
@24 set I1 0
@25 set I1 1
@26 set I1 0
@27 set I1 1
@28 set I1 0
@29 set I1 1
@30 set I1 0
@31 set I1 1
@32 set I1 0
@33 set I1 1
@33 expect O1 0.063988 tol 1e-5   # bar1 chaotic step 0: redrawn
@34 set I1 0
@35 set I1 1
@35 expect O1 0.105669 tol 1e-5   # bar1 det step 1: same value
@36 set I1 0
@37 set I1 1
