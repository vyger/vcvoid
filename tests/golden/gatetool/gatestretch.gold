# gatetool: manual example -- gatestretch makes the output gate longer than the
# input gate by a percentage. You can't shorten (no looking into the future), so
# the stretch is added AFTER the input falls. tickrate 100, gatestretch 0.5 (+50%).
#
# Input gate high t0..t19 (D = 20). Output length = 20 * (1 + 0.5) = 30 ticks:
# high t0..t29, low from t30. So the output stays high 10 ticks past the input fall.
tickrate 100
patch <<<
[gatetool]
    inputgate   = I1
    outputgate  = O1
    gatestretch = 0.5
>>>
@0 set I1 1
@19 expect O1 1 tol 1e-4
@20 set I1 0
@20 expect O1 1 tol 1e-4
@29 expect O1 1 tol 1e-4
@30 expect O1 0 tol 1e-4
