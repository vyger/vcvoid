# gatetool: manual example -- inputgate + gatelength. When gatelength is used, the
# input gate's own length is ignored and overruled by the parameter (the inputgate
# behaves like a trigger at its rising edge). tickrate 100 -> gatelength 0.5 s = 50.
#
# Short input gate t0..t9 (D=10): output is a fixed 50-tick gate t0..t49 (NOT 10),
# proving the input length is overruled.
tickrate 100
patch <<<
[gatetool]
    inputgate  = I1
    outputgate = O1
    gatelength = 0.5
>>>
@0 set I1 1
@10 set I1 0
@10 expect O1 1 tol 1e-4
@49 expect O1 1 tol 1e-4
@50 expect O1 0 tol 1e-4
