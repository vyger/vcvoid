# `reset`: "Send a trigger here to immediately stop any ongoing burst."
# Trigger at t1 starts a 3-pulse burst; a reset at t3 kills it mid-pulse-1.
# Output drops to 0 on t3 (without the reset, t3 would still be high) and no
# further pulses (2 or 3) are ever emitted.
tickrate 8
patch <<<
[burst]
    trigger = I1
    reset   = I3
    hz      = 1
    count   = 3
    output  = O1
>>>
@0 expect O1 0
@1 set I1 1
@1 expect O1 1
@2 set I1 0
@2 expect O1 1
@3 set I3 1
@3 expect O1 0
@4 set I3 0
@4 expect O1 0
@9 expect O1 0
@17 expect O1 0
