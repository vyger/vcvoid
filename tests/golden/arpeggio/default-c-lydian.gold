# arpeggio manual "simplest possible example": clock -> output, all defaults.
# root=0 degree=0 -> C Lydian scale {C,D,E,F#,G,A,B} = pcs {0,2,4,6,7,9,11}.
# No selects patched -> smart default = all seven scale notes.
# pitch=0, range=2V (0.2) -> notes across [0,24] semitones: 15 notes (C thrice).
# pattern=0 (default) = step forward through the allowed notes.
# 1 semitone = 0.1/12 = 0.0083333 engine. Each clock advances one note.
# Sequence of semitones: 0,2,4,6,7,9,11,12,14,16,18,19,21,23,24 then wraps to 0.
# I1 = clock, O1 = output. Rising edge (0->1) advances; first edge = note 1.
patch <<<
[arpeggio]
    clock  = I1
    output = O1
>>>
# before the first clock nothing has been emitted -> hold 0 V
@0 expect O1 0 tol 1e-5
@1 set I1 1
@1 expect O1 0 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.0166667 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0.0333333 tol 1e-5
@6 set I1 0
@7 set I1 1
@7 expect O1 0.05 tol 1e-5
@8 set I1 0
@9 set I1 1
@9 expect O1 0.0583333 tol 1e-5
@10 set I1 0
@11 set I1 1
@11 expect O1 0.075 tol 1e-5
@12 set I1 0
@13 set I1 1
@13 expect O1 0.0916667 tol 1e-5
@14 set I1 0
@15 set I1 1
@15 expect O1 0.1 tol 1e-5
@16 set I1 0
# advance through notes 9..14 (semis 14,16,18,19,21,23) without checking
@17 set I1 1
@18 set I1 0
@19 set I1 1
@20 set I1 0
@21 set I1 1
@22 set I1 0
@23 set I1 1
@24 set I1 0
@25 set I1 1
@26 set I1 0
@27 set I1 1
@28 set I1 0
# note 15 = semi 24 = top of range = 0.2 (the third C)
@29 set I1 1
@29 expect O1 0.2 tol 1e-5
@30 set I1 0
# note 16 wraps back to the first note (semi 0)
@31 set I1 1
@31 expect O1 0 tol 1e-5
