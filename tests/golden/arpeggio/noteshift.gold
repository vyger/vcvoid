# arpeggio noteshift / selectnoteshift (shared with minifonion's note core).
# noteshift shifts the output by scale notes; selectnoteshift by selected notes.
# O1: noteshift=1, C Lydian all-7 pool {0,2,4,6,7,9,11,...}. Each pool note is
#     shifted up one SCALE note: 0->2, 2->4, 4->6, 6->7 -> semis 2,4,6,7.
# O2: selectnoteshift=1, triad select1/3/5 = {0,4,7,12,...}. Each note is shifted
#     up one SELECTED note: 0->4, 4->7, 7->12(next oct), 12->16 -> semis 4,7,12,16.
patch <<<
[arpeggio]
    clock     = I1
    output    = O1
    pitch     = 0
    noteshift = 1
>>>
patch <<<
[arpeggio]
    clock           = I1
    output          = O2
    pitch           = 0
    select1         = 1
    select3         = 1
    select5         = 1
    selectnoteshift = 1
>>>
@1 set I1 1
@1 expect O1 0.0166667 tol 1e-5
@1 expect O2 0.0333333 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.0333333 tol 1e-5
@3 expect O2 0.0583333 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0.05 tol 1e-5
@5 expect O2 0.1 tol 1e-5
@6 set I1 0
@7 set I1 1
@7 expect O1 0.0583333 tol 1e-5
@7 expect O2 0.1333333 tol 1e-5
