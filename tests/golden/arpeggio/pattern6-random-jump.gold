# arpeggio pattern 6: random jump to any OTHER allowed note each clock.
# Determinism golden: seed=1 xorshift32, one nextRand draw per note after the
# first; index = draw % (M-1), bumped up by 1 if it would land on the current
# index (so it is always a different note). C Lydian, range=1V ->
# pool semis {0,2,4,6,7,9,11,12}, indices 0..7 (start idx 0).
# Computed index walk (seed 1): 0,2,4,7,4,3,6,0,2,4,6,1
#   semis: 0,4,7,12,7,6,11,0,4,7,11,2
seed 1
patch <<<
[arpeggio]
    clock   = I1
    output  = O1
    pitch   = 0
    range   = 1V
    pattern = 6
>>>
@1 set I1 1
@1 expect O1 0 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.0333333 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0.0583333 tol 1e-5
@6 set I1 0
@7 set I1 1
@7 expect O1 0.1 tol 1e-5
@8 set I1 0
@9 set I1 1
@9 expect O1 0.0583333 tol 1e-5
@10 set I1 0
@11 set I1 1
@11 expect O1 0.05 tol 1e-5
@12 set I1 0
@13 set I1 1
@13 expect O1 0.0916667 tol 1e-5
@14 set I1 0
@15 set I1 1
@15 expect O1 0 tol 1e-5
@16 set I1 0
@17 set I1 1
@17 expect O1 0.0333333 tol 1e-5
@18 set I1 0
@19 set I1 1
@19 expect O1 0.0583333 tol 1e-5
@20 set I1 0
@21 set I1 1
@21 expect O1 0.0916667 tol 1e-5
@22 set I1 0
@23 set I1 1
@23 expect O1 0.0166667 tol 1e-5
