# arpeggio butterfly: reorder the pool by interleaving from both ends. The
# manual's example: notes 1..10 become 1,10,2,9,3,8,4,7,5,6.
# C Lydian, pitch=0, range=7 semitones (0.0583333) -> pool semis {0,2,4,6,7}
# (5 notes). Butterfly order: 1,5,2,4,3 -> pool indices 0,4,1,3,2 ->
# semis {0,7,2,6,4}. pattern 0 walks that order, then wraps.
#   semis: 0,7,2,6,4,0(wrap)
patch <<<
[arpeggio]
    clock     = I1
    output    = O1
    pitch     = 0
    range     = 0.0583333
    butterfly = 1
>>>
@1 set I1 1
@1 expect O1 0 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.0583333 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0.0166667 tol 1e-5
@6 set I1 0
@7 set I1 1
@7 expect O1 0.05 tol 1e-5
@8 set I1 0
@9 set I1 1
@9 expect O1 0.0333333 tol 1e-5
@10 set I1 0
@11 set I1 1
@11 expect O1 0 tol 1e-5
