# arpeggio SPEC-GAP: empty allowed-note set. harmonicshift=-7 disables all seven
# scale notes (fills untouched, none selected), so selectedNotes() is empty.
# The manual does not define arpeggio output when no note is allowed; the literal
# reading is that no note is ever emitted, so the held note stays at its initial
# 0 V. transpose=0.025 makes that observable: the output is a constant 0.025
# (0 held + transpose), never a scale note, across every clock.
patch <<<
[arpeggio]
    clock         = I1
    output        = O1
    harmonicshift = -7
    transpose     = 0.025
>>>
@1 set I1 1
@1 expect O1 0.025 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.025 tol 1e-5
@5 set I1 0
@7 set I1 1
@7 expect O1 0.025 tol 1e-5
