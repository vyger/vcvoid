# arpeggio manual example: D natural minor arpeggiated, starting at D.
# root=2 (D), degree=7 (natural minor / aeolian). Smart default = all 7 scale
# notes. D natural minor = D E F G A Bb C -> pcs {2,4,5,7,9,10,0}.
# pitch=2/120 = 0.0166667 (2 semitones = D) so the range starts at D; range=1V
# (0.1) -> one octave window [2,14] semitones.
# Pool (ascending): 2(D),4(E),5(F),7(G),9(A),10(Bb),12(C),14(D) = 8 notes.
# pattern 0: step forward, then wrap to the first note.
patch <<<
[arpeggio]
    clock  = I1
    output = O1
    root   = 2
    degree = 7
    pitch  = 0.0166667
    range  = 1V
>>>
@1 set I1 1
@1 expect O1 0.0166667 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.0333333 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0.0416667 tol 1e-5
@6 set I1 0
@7 set I1 1
@7 expect O1 0.0583333 tol 1e-5
@8 set I1 0
@9 set I1 1
@9 expect O1 0.075 tol 1e-5
@10 set I1 0
@11 set I1 1
@11 expect O1 0.0833333 tol 1e-5
@12 set I1 0
@13 set I1 1
@13 expect O1 0.1 tol 1e-5
@14 set I1 0
@15 set I1 1
@15 expect O1 0.1166667 tol 1e-5
@16 set I1 0
# note 9 wraps back to D (semi 2)
@17 set I1 1
@17 expect O1 0.0166667 tol 1e-5
