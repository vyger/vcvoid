# arpeggio direction=1: start at the highest allowed note and reverse the
# pattern (go downwards). Pool semis {0,2,4,6,7}, indices 0..4; start at idx 4.
# pattern 0 downward:
#   idx: 4,3,2,1,0,then -1 out of range -> restart to top (idx 4)
#   semis: 7,6,4,2,0,7
patch <<<
[arpeggio]
    clock     = I1
    output    = O1
    direction = 1
    pitch     = 0
    range     = 0.0583333
>>>
@1 set I1 1
@1 expect O1 0.0583333 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.05 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0.0333333 tol 1e-5
@6 set I1 0
@7 set I1 1
@7 expect O1 0.0166667 tol 1e-5
@8 set I1 0
@9 set I1 1
@9 expect O1 0 tol 1e-5
@10 set I1 0
# reached the bottom -> restart at the top note (G, semi 7)
@11 set I1 1
@11 expect O1 0.0583333 tol 1e-5
