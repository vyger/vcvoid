# arpeggio reset: a trigger to `reset` restarts the pattern at its first step.
# Within a tick, reset is processed before clock, so a simultaneous reset+clock
# lands on the start note (SPEC-GAP convention: reset-before-clock; only the
# general "reset restarts" behaviour is documented).
# C Lydian, pitch=0, range=1V -> pool semis {0,2,4,6,7,9,11,12}. pattern 0.
patch <<<
[arpeggio]
    clock  = I1
    reset  = I2
    output = O1
    pitch  = 0
    range  = 1V
>>>
@1 set I1 1
@1 expect O1 0 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.0166667 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0.0333333 tol 1e-5
@6 set I1 0
# simultaneous reset + clock -> reset wins, emit the start note (semi 0)
@7 set I1 1
@7 set I2 1
@7 expect O1 0 tol 1e-5
@8 set I1 0
@8 set I2 0
# pattern continues from the start
@9 set I1 1
@9 expect O1 0.0166667 tol 1e-5
