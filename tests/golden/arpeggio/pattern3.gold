# arpeggio pattern 3: "double step forward, double step backward, single step
# forward" (=><=->). Pool semis {0,2,4,6,7}, indices 0..4.
# Delta cycle [+2,-2,+1]:
#   idx: 0,2,0,1,3,1,2,4,2,3,then +2 would hit 5 -> restart to 0
#   semis: 0,4,0,2,6,2,4,7,4,6,0
patch <<<
[arpeggio]
    clock   = I1
    output  = O1
    pitch   = 0
    range   = 0.0583333
    pattern = 3
>>>
@1 set I1 1
@1 expect O1 0 tol 1e-5
@2 set I1 0
@3 set I1 1
@3 expect O1 0.0333333 tol 1e-5
@4 set I1 0
@5 set I1 1
@5 expect O1 0 tol 1e-5
@6 set I1 0
@7 set I1 1
@7 expect O1 0.0166667 tol 1e-5
@8 set I1 0
@9 set I1 1
@9 expect O1 0.05 tol 1e-5
@10 set I1 0
@11 set I1 1
@11 expect O1 0.0166667 tol 1e-5
@12 set I1 0
@13 set I1 1
@13 expect O1 0.0333333 tol 1e-5
@14 set I1 0
@15 set I1 1
@15 expect O1 0.0583333 tol 1e-5
@16 set I1 0
@17 set I1 1
@17 expect O1 0.0333333 tol 1e-5
@18 set I1 0
@19 set I1 1
@19 expect O1 0.05 tol 1e-5
@20 set I1 0
@21 set I1 1
@21 expect O1 0 tol 1e-5
