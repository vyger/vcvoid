# button: patching value3 (without a `states` input) auto-derives states = 3.
# value1/value2 keep defaults 0/1, value3 = 0.5. Cycle wraps 0->1->2->0.
# led = E/(states-1) = 0, 0.5, 1.
tickrate 100
patch <<<
[p2b8]

[button]
    button = B1.1
    led    = L1.1
    value3 = 0.5
    output = _S

[copy]
    input  = _S
    output = O1
>>>
@0 expect _S 0 tol 1e-4
@0 expect L1.1 0 tol 1e-4
@1 set B1.1 1
@1 expect _S 1 tol 1e-4
@1 expect L1.1 0.5 tol 1e-4
@2 set B1.1 0
@3 set B1.1 1
@3 expect _S 0.5 tol 1e-4
@3 expect L1.1 1 tol 1e-4
@4 set B1.1 0
@5 set B1.1 1
@5 expect _S 0 tol 1e-4
@5 expect L1.1 0 tol 1e-4
@6 set B1.1 0
