# button: `select` gates BOTH button processing and led writing (overlays),
# while output keeps emitting the latched state. A press made while deselected
# is not processed and produces no phantom toggle on reselect (edge state is
# tracked every tick). select = I7 (positive gate selects).
#   t0 selected, state 0            -> led 0, output 0
#   t1 press (selected) -> state 1  -> led 1, output 1
#   t3 deselect -> output still 1 (latched); led left untouched (holds 1)
#   t4/t5 press+release while DESELECTED -> not processed (state stays 1)
#   t6 reselect -> no phantom edge -> state still 1 -> led 1, output 1
#   t7 press (selected) -> state 0  -> led 0, output 0
tickrate 100
patch <<<
[p2b8]

[button]
    select = I7
    button = B1.1
    led    = L1.1
    output = O1
>>>
@0 set I7 1
@0 expect L1.1 0 tol 1e-4
@0 expect O1 0 tol 1e-4
@1 set B1.1 1
@1 expect L1.1 1 tol 1e-4
@1 expect O1 1 tol 1e-4
@2 set B1.1 0
@3 set I7 0
@3 expect O1 1 tol 1e-4
@3 expect L1.1 1 tol 1e-4
@4 set B1.1 1
@5 set B1.1 0
@5 expect O1 1 tol 1e-4
@6 set I7 1
@6 expect O1 1 tol 1e-4
@6 expect L1.1 1 tol 1e-4
@7 set B1.1 1
@7 expect O1 0 tol 1e-4
@7 expect L1.1 0 tol 1e-4
@8 set B1.1 0
