# button: doubleclickmode. A lone press momentarily INVERTS the persisted state
# while held; a double press (two rising edges within the window) TOGGLES the
# persisted state. states = 2. SPEC-GAP: the manual gives no double-click window
# for `button`; we use 0.5 s -> 50 ticks at tickrate 100.
#
#   t1 press (1st click) -> momentary invert: E = 1-0 = 1 -> led 1, output 1
#   t2 release           -> E = P = 0 -> led 0
#   t3 press (2nd click, within 50 ticks) -> TOGGLE P to 1; E = 1-1 = 0 -> led 0
#   t4 release           -> E = P = 1 -> led 1, output 1   (now latched on)
#   t10 press (lone)     -> momentary invert of on: E = 1-1 = 0 -> led 0
#   t11 release          -> E = P = 1 -> led 1   (single press did NOT toggle)
#   t70 press            -> >50 ticks since t10: fresh 1st click, no toggle;
#                           E = 1-1 = 0 -> led 0
#   t71 release          -> E = P = 1 -> led 1   (window elapsed: no double-click)
tickrate 100
patch <<<
[p2b8]

[button]
    button          = B1.1
    led             = L1.1
    output          = O1
    doubleclickmode = 1
>>>
@0 expect L1.1 0 tol 1e-4
@1 set B1.1 1
@1 expect L1.1 1 tol 1e-4
@1 expect O1 1 tol 1e-4
@2 set B1.1 0
@2 expect L1.1 0 tol 1e-4
@3 set B1.1 1
@3 expect L1.1 0 tol 1e-4
@4 set B1.1 0
@4 expect L1.1 1 tol 1e-4
@4 expect O1 1 tol 1e-4
@10 set B1.1 1
@10 expect L1.1 0 tol 1e-4
@11 set B1.1 0
@11 expect L1.1 1 tol 1e-4
@70 set B1.1 1
@70 expect L1.1 0 tol 1e-4
@71 set B1.1 0
@71 expect L1.1 1 tol 1e-4
