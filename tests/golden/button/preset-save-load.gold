# button: triggered presets. Save the current state to preset 0, change it, then
# load preset 0 back. preset = I6 (=0), savepreset = I7, loadpreset = I8.
#   t1 press -> state 1
#   t3 savepreset -> preset 0 = state 1
#   t5 press -> state 0
#   t7 loadpreset -> state = preset 0 = 1 -> output 1
tickrate 100
patch <<<
[p2b8]

[button]
    button     = B1.1
    led        = L1.1
    output     = O1
    preset     = I6
    savepreset = I7
    loadpreset = I8
>>>
@0 expect O1 0 tol 1e-4
@1 set B1.1 1
@1 expect O1 1 tol 1e-4
@2 set B1.1 0
@3 set I7 1
@4 set I7 0
@5 set B1.1 1
@5 expect O1 0 tol 1e-4
@6 set B1.1 0
@7 set I8 1
@7 expect O1 1 tol 1e-4
@8 set I8 0
