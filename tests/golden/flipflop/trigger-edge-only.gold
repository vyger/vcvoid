# Trigger inputs fire on the rising edge only: holding toggle's source high
# across many ticks must not re-toggle every tick.
patch <<<
[flipflop]
    toggle = I1
    output = O1
>>>
@0  expect O1 0
@1  set I1 1
@1  expect O1 1
@2  expect O1 1
@3  expect O1 1
@9  expect O1 1
@10 set I1 0
@10 expect O1 1
@11 set I1 1
@11 expect O1 0
