# matrixmixer: the three startvalue configurations, one circuit each (distinct
# output registers so there is no duplicate-output problem). Inputs I1=0.3,
# I2=0.2 are shared.
#   startvalue 0 (all clear):    output1 has no enabled inputs -> 0
#   startvalue 1 (diagonal):     input1 -> output1            -> 0.3
#   startvalue 2 (all set):      every input -> output1 -> 0.3+0.2 = 0.5
tickrate 100
patch <<<
[matrixmixer]
    startvalue = 0
    input1  = I1
    output1 = O1
>>>

patch <<<
[matrixmixer]
    startvalue = 1
    input1  = I1
    output1 = O2
>>>

patch <<<
[matrixmixer]
    startvalue = 2
    input1  = I1
    input2  = I2
    output1 = O3
>>>
@0 set I1 0.3
@0 set I2 0.2
@0 expect O1 0 tol 1e-4
@0 expect O2 0.3 tol 1e-4
@0 expect O3 0.5 tol 1e-4
