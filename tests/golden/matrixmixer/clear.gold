# matrixmixer: a `clear` trigger reloads the start state (here the diagonal,
# startvalue 1). Toggling button11 off removes input1->output1; clear restores
# the diagonal.
#   t0: diagonal -> O1 = input1 = 0.5
#   t1: press button11 -> toggle off -> O1 = 0
#   t3: clear -> diagonal restored -> O1 = 0.5
tickrate 100
patch <<<
[matrixmixer]
    startvalue = 1
    input1   = I1
    output1  = O1
    button11 = I5
    clear    = I6
>>>
@0 set I1 0.5
@0 expect O1 0.5 tol 1e-4
@1 set I5 1
@1 expect O1 0 tol 1e-4
@2 set I5 0
@3 set I6 1
@3 expect O1 0.5 tol 1e-4
@4 set I6 0
