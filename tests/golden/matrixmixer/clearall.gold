# matrixmixer: `clearall` reloads the start state into the circuit AND wipes all
# presets (unlike `clear`, which leaves presets intact). We save a node to
# preset 0, clearall, then load preset 0 -- and it comes back EMPTY, proving the
# preset was wiped. Contrast preset-save-load.gold, where the load restores 0.6.
# preset = I6 (0), savepreset = I7, loadpreset = I8, clearall = I2.
tickrate 100
patch <<<
[matrixmixer]
    startvalue = 0
    input1     = I1
    output1    = O1
    button11   = I5
    preset     = I6
    savepreset = I7
    loadpreset = I8
    clearall   = I2
>>>
@0 set I1 0.6
@1 set I5 1
@2 set I5 0
@2 expect O1 0.6 tol 1e-4
@3 set I7 1
@4 set I7 0
@5 set I2 1
@5 expect O1 0 tol 1e-4
@6 set I2 0
@7 set I8 1
@7 expect O1 0 tol 1e-4
@8 set I8 0
