# encoderbank: a preset stores ALL lanes at once (8 slots). Two lanes, smooth 0.
#   @1 E1.1 +96 -> O1 1.0 ; E1.2 +48 -> O2 0.5
#   @2 savepreset (slot 0) stores both
#   @4 turn both back to 0
#   @5 loadpreset (slot 0) restores O1 1.0, O2 0.5
tickrate 100
patch <<<
[e4]

[encoderbank]
    firstencoder = E1.1
    output1      = O1
    output2      = O2
    preset       = I2
    savepreset   = I3
    loadpreset   = I4
    smooth       = 0
>>>
@1 turn E1.1 96
@1 turn E1.2 48
@1 expect O1 1.0 tol 1e-4
@1 expect O2 0.5 tol 1e-4
@2 set I2 0
@2 set I3 1
@3 set I3 0
@4 turn E1.1 -96
@4 turn E1.2 -48
@4 expect O1 0.0 tol 1e-4
@4 expect O2 0.0 tol 1e-4
@5 set I4 1
@5 expect O1 1.0 tol 1e-4
@5 expect O2 0.5 tol 1e-4
