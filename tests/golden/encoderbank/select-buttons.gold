# encoderbank: per-lane push buttons, gated by select. Bank size = 2 (highest of
# output2 / button2). button<N> = the encoder's push state, but only while the
# bank is selected. select = I1.
#   @1 select on + push both -> button1/2 = 1
#   @2 deselect (still pushed) -> button1/2 = 0
#   @3 reselect -> button1/2 = 1
tickrate 100
patch <<<
[e4]

[encoderbank]
    firstencoder = E1.1
    output1      = O1
    output2      = O2
    button1      = O3
    button2      = O4
    select       = I1
>>>
@0 expect O3 0 tol 1e-4
@1 set I1 1
@1 push E1.1 1
@1 push E1.2 1
@1 expect O3 1 tol 1e-4
@1 expect O4 1 tol 1e-4
@2 set I1 0
@2 expect O3 0 tol 1e-4
@2 expect O4 0 tol 1e-4
@3 set I1 1
@3 expect O3 1 tol 1e-4
@3 expect O4 1 tol 1e-4
