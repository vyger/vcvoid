# notebuttons: `startnote` seeds the selected note at boot; `clear` reseeds it
# and `clearall` reseeds it too (both load the default start state). startnote 5.
# `output` is read through the internal cable `_OUT` (physical O jacks clamp
# above 1.0); `[copy]` is its required reader.
#   t0 boot -> output 5
#   t1 press button8 (note 7) -> output 7
#   t3 clear (I1) -> reseed startnote -> output 5
#   t5 press button2 (note 1)  -> output 1
#   t7 clearall (I2) -> reseed startnote -> output 5
tickrate 100
patch <<<
[b32]

[notebuttons]
    startnote = 5
    button2   = B1.2
    button8   = B1.8
    clear     = I1
    clearall  = I2
    output    = _OUT

[copy]
    input = _OUT
>>>
@0 expect _OUT 5 tol 1e-4
@1 set B1.8 1
@1 expect _OUT 7 tol 1e-4
@2 set B1.8 0
@3 set I1 1
@3 expect _OUT 5 tol 1e-4
@4 set I1 0
@5 set B1.2 1
@5 expect _OUT 1 tol 1e-4
@6 set B1.2 0
@7 set I2 1
@7 expect _OUT 5 tol 1e-4
@8 set I2 0
