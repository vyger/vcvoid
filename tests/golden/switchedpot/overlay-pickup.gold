# switchedpot (obsolete; superseded by pot -- crosscheck reports it deprecated).
# One physical pot P1.1 drives two virtual pots gated by switch1=B1.1 / switch2=
# B1.2 (held while turning). Both start at 0.5; the active one tracks the pot via
# the proportional pickup; an inactive one freezes but keeps emitting. prevPhys
# is tracked every tick so toggling a switch causes no phantom jump.
#   t0 phys .5, sw1 on : v1 stays .5, v2 frozen .5          -> O1 .5  O2 .5
#   t1 phys ->1: v1 pickup .5->1.0                          -> O1 1   O2 .5
#   t2 hand over: sw1 off, sw2 on (phys still 1)            -> O1 1   O2 .5
#   t3 phys ->.5: v2 pickup .5->.25 (v2 -= .5*.5/1); v1 1   -> O1 1   O2 .25
#   t4 phys ->0 : v2 pickup .25->0 (both reach 0 together)  -> O1 1   O2 0
#   t5 sw1 back on (both active), phys 0                    -> O1 1   O2 0
#   t6 phys ->.5: v1 was 1 (maxed, no rise); v2 0->.5       -> O1 1   O2 .5
tickrate 100
patch <<<
[p2b8]

[switchedpot]
    pot     = P1.1
    switch1 = B1.1
    switch2 = B1.2
    output1 = O1
    output2 = O2
>>>
@0 set P1.1 0.5
@0 set B1.1 1
@0 expect O1 0.5 tol 1e-4
@0 expect O2 0.5 tol 1e-4
@1 set P1.1 1.0
@1 expect O1 1 tol 1e-4
@1 expect O2 0.5 tol 1e-4
@2 set B1.1 0
@2 set B1.2 1
@2 expect O1 1 tol 1e-4
@2 expect O2 0.5 tol 1e-4
@3 set P1.1 0.5
@3 expect O1 1 tol 1e-4
@3 expect O2 0.25 tol 1e-4
@4 set P1.1 0.0
@4 expect O1 1 tol 1e-4
@4 expect O2 0 tol 1e-4
@5 set B1.1 1
@5 expect O1 1 tol 1e-4
@5 expect O2 0 tol 1e-4
@6 set P1.1 0.5
@6 expect O1 1 tol 1e-4
@6 expect O2 0.5 tol 1e-4
