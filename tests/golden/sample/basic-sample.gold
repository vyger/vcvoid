# sample & hold worked example: a rising edge at `sample` reads `input` and holds
# it at `output`. Before the first sample the output is 0. I1=input I2=sample.
patch <<<
[sample]
    input  = I1
    sample = I2
    output = O1
>>>
@0 set I1 0.3
@0 expect O1 0
# sample -> hold 0.3
@1 set I2 1
@1 expect O1 0.3
# input changes but no new trigger -> hold 0.3
@2 set I2 0
@2 set I1 0.7
@2 expect O1 0.3
# next trigger -> hold 0.7
@3 set I2 1
@3 expect O1 0.7
@4 set I2 0
@4 set I1 0.2
@4 expect O1 0.7
